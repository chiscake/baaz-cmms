<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="BAAZ.CMMS.App.Controls.CrudWorkbench.CrudPaginatorControl"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="PaginatorIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Background" Value="{ThemeResource ControlFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource ControlStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="PaginatorPageSizeButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Background" Value="{ThemeResource ControlFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource ControlStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="12" />
        </Style>
    </UserControl.Resources>

    <Grid MinHeight="36"
          VerticalAlignment="Center">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center">
            <Button Style="{StaticResource PaginatorIconButtonStyle}"
                    Command="{Binding GoToPreviousPageCommand}"
                    IsEnabled="{Binding CanGoToPreviousPage}">
                <FontIcon Glyph="&#xE76B;"
                          FontSize="10" />
            </Button>

            <StackPanel Orientation="Horizontal"
                        Spacing="8"
                        VerticalAlignment="Center">
                <TextBlock Text="{Binding PaginationPageLabel}"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                <NumberBox Width="88"
                           Minimum="1"
                           Maximum="{Binding TotalPages}"
                           Value="{Binding CurrentPage, Mode=TwoWay}"
                           SpinButtonPlacementMode="Hidden"
                           SmallChange="1"
                           LargeChange="1"
                           FontSize="12"
                           HorizontalContentAlignment="Center"
                           VerticalContentAlignment="Center"
                           Background="{ThemeResource ControlFillColorDefaultBrush}"
                           BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" />

                <TextBlock Text="{Binding PaginationOfText}"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <Button Style="{StaticResource PaginatorIconButtonStyle}"
                    Command="{Binding GoToNextPageCommand}"
                    IsEnabled="{Binding CanGoToNextPage}">
                <FontIcon Glyph="&#xE76C;"
                          FontSize="10" />
            </Button>

            <Button x:Name="PageSizeButton"
                    Style="{StaticResource PaginatorPageSizeButtonStyle}"
                    Content="{Binding PaginationPageSizeText}"
                    Click="PageSizeButton_Click" />
        </StackPanel>

        <TextBlock Grid.Column="2"
                   Text="{Binding PaginationRecordsText}"
                   VerticalAlignment="Center"
                   FontSize="12"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
    </Grid>
</UserControl>
