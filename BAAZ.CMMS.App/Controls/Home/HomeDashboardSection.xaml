<?xml version="1.0" encoding="utf-8"?>

<UserControl x:Class="BAAZ.CMMS.App.Controls.Home.HomeDashboardSection"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:home="using:BAAZ.CMMS.App.Controls.Home"
             xmlns:local="using:BAAZ.CMMS.App.Controls.Home"
             xmlns:controls="using:CommunityToolkit.WinUI.Controls"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <UserControl.Resources>
        <local:BoolToVisibilityConverter x:Key="HomeBoolToVisibility" />
        <local:InverseBoolToVisibilityConverter x:Key="HomeInverseBoolToVisibility" />
    </UserControl.Resources>

    <StackPanel Spacing="16">
        <StackPanel Spacing="8">
            <StackPanel Orientation="Horizontal"
                        Spacing="8">
                <Ellipse Width="8"
                         Height="8"
                         VerticalAlignment="Center"
                         Fill="{ThemeResource AccentFillColorDefaultBrush}" />
                <TextBlock CharacterSpacing="80"
                           Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           Text="{Binding RoleLabel, Mode=OneWay}" />
            </StackPanel>
            <TextBlock Style="{ThemeResource TitleTextBlockStyle}"
                       Text="{Binding SectionHeading, Mode=OneWay}" />
        </StackPanel>

        <ProgressRing Width="32"
                      Height="32"
                      HorizontalAlignment="Left"
                      IsActive="{Binding IsLoading, Mode=OneWay}"
                      Visibility="{Binding IsLoading, Mode=OneWay, Converter={StaticResource HomeBoolToVisibility}}" />

        <ItemsControl ItemsSource="{Binding StatRows, Mode=OneWay}"
                      Visibility="{Binding IsLoading, Mode=OneWay, Converter={StaticResource HomeInverseBoolToVisibility}}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Spacing="12" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="home:HomeStatRow">
                    <Grid RowDefinitions="Auto,Auto"
                          RowSpacing="8">
                        <Grid Grid.Row="0"
                              Margin="0,0,-12,0"
                              ColumnSpacing="12"
                              Visibility="{Binding HasHeading, Mode=OneWay, Converter={StaticResource HomeBoolToVisibility}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Grid.ColumnSpan="{Binding PrimaryHeadingColumnSpan, Mode=OneWay}"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       Text="{Binding Heading, Mode=OneWay}" />
                            <TextBlock Grid.Column="3"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       Text="{Binding SecondaryHeading, Mode=OneWay}"
                                       Visibility="{Binding HasSecondaryHeading, Mode=OneWay, Converter={StaticResource HomeBoolToVisibility}}" />
                        </Grid>
                        <ItemsControl Grid.Row="1"
                                      Margin="0,0,-12,-12"
                                      ItemsSource="{Binding Items, Mode=OneWay}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <controls:UniformGrid Columns="{Binding Columns, Mode=OneWay}" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="HorizontalAlignment" Value="Stretch" />
                                    <Setter Property="VerticalAlignment" Value="Stretch" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="home:HomeStatItem">
                                    <home:HomeStatTile Margin="0,0,12,12"
                                                       HorizontalAlignment="Stretch"
                                                       DataContext="{Binding Mode=OneWay}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <ItemsControl Margin="0,0,-12,-12"
                      ItemsSource="{Binding Actions, Mode=OneWay}"
                      Visibility="{Binding IsLoading, Mode=OneWay, Converter={StaticResource HomeInverseBoolToVisibility}}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <controls:UniformGrid Columns="4" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemContainerStyle>
                <Style TargetType="ContentPresenter">
                    <Setter Property="HorizontalAlignment" Value="Stretch" />
                    <Setter Property="VerticalAlignment" Value="Stretch" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
            </ItemsControl.ItemContainerStyle>
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="home:HomeQuickAction">
                    <home:HomeQuickActionButton Margin="0,0,12,12"
                                                HorizontalAlignment="Stretch"
                                                DataContext="{Binding Mode=OneWay}" />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <ItemsControl ItemsSource="{Binding NavLinks, Mode=OneWay}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="home:HomeNavLink">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Margin="4,0"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorDisabledBrush}"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Text="•"
                                   Visibility="{Binding ShowSeparator, Mode=OneWay, Converter={StaticResource HomeBoolToVisibility}}" />
                        <HyperlinkButton Padding="0"
                                         VerticalAlignment="Center"
                                         Command="{Binding NavigateCommand, Mode=OneWay}"
                                         CommandParameter="{Binding Mode=OneWay}"
                                         Content="{Binding Title, Mode=OneWay}"
                                         FontSize="{ThemeResource ControlContentThemeFontSize}"
                                         Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</UserControl>
