<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="BAAZ.CMMS.App.Controls.MaintenanceScheduleChart.MaintenanceScheduleTimelineControl"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="using:BAAZ.CMMS.App.Controls.MaintenanceScheduleChart"
             xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
             mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="ChartPrimaryLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="ChartSecondaryLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="ChartHeaderCaptionStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource CaptionTextBlockStyle}">
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
        </Style>
        <Style x:Key="ChartHeaderAccentStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource CaptionTextBlockStyle}">
            <Setter Property="Foreground" Value="{ThemeResource AccentTextFillColorPrimaryBrush}" />
        </Style>
    </UserControl.Resources>

    <Grid RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    Spacing="8">
            <Button x:Name="PrevButton" />
            <TextBlock x:Name="RangeText"
                       VerticalAlignment="Center"
                       Style="{ThemeResource BodyStrongTextBlockStyle}" />
            <Button x:Name="NextButton" />
            <Button x:Name="TodayButton" />
            <SelectorBar x:Name="ZoomSelector"
                         Style="{StaticResource TokenViewSelectorBarStyle}"
                         SelectionChanged="ZoomSelector_SelectionChanged">
                <SelectorBarItem Text="{Binding ChartZoomWeekLabel, Mode=OneWay}" />
                <SelectorBarItem Text="{Binding ChartZoomMonthLabel, Mode=OneWay}"
                                 IsSelected="True" />
                <SelectorBarItem Text="{Binding ChartZoomQuarterLabel, Mode=OneWay}" />
            </SelectorBar>
        </StackPanel>

        <Border Grid.Row="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel x:Name="LabelsHeaderPanel"
                                Grid.Row="0" />

                    <ScrollViewer x:Name="LabelsScroll"
                                  Grid.Row="1"
                                  VerticalScrollBarVisibility="Hidden"
                                  VerticalScrollMode="Enabled"
                                  HorizontalScrollBarVisibility="Disabled"
                                  ViewChanged="LabelsScroll_ViewChanged">
                        <muxc:ItemsRepeater x:Name="LabelsRepeater">
                            <muxc:ItemsRepeater.Layout>
                                <muxc:StackLayout Orientation="Vertical" />
                            </muxc:ItemsRepeater.Layout>
                            <muxc:ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="local:ChartLaneRowVm">
                                    <Border Height="36" />
                                </DataTemplate>
                            </muxc:ItemsRepeater.ItemTemplate>
                        </muxc:ItemsRepeater>
                    </ScrollViewer>
                </Grid>

                <Border Grid.Column="1"
                        Width="1"
                        Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border x:Name="HeaderBorder"
                            Grid.Row="0"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <ScrollViewer x:Name="HeaderScroll"
                                        HorizontalScrollBarVisibility="Hidden"
                                        HorizontalScrollMode="Enabled"
                                        VerticalScrollBarVisibility="Disabled"
                                        VerticalScrollMode="Disabled"
                                        ViewChanged="HeaderScroll_ViewChanged">
                            <StackPanel>
                                <Canvas x:Name="HeatMapCanvas"
                                        Height="8" />
                                <Canvas x:Name="HeaderCanvas"
                                        Height="48" />
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <ScrollViewer x:Name="GridScroll"
                                  Grid.Row="1"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  ViewChanged="GridScroll_ViewChanged">
                        <Grid x:Name="LaneHost"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Top">
                            <muxc:ItemsRepeater x:Name="GridRepeater"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Top">
                                <muxc:ItemsRepeater.Layout>
                                    <muxc:StackLayout Orientation="Vertical" />
                                </muxc:ItemsRepeater.Layout>
                                <muxc:ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="local:ChartLaneRowVm">
                                        <Canvas Height="36" />
                                    </DataTemplate>
                                </muxc:ItemsRepeater.ItemTemplate>
                            </muxc:ItemsRepeater>
                            <Canvas x:Name="LaneGridOverlay"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    IsHitTestVisible="False" />
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
