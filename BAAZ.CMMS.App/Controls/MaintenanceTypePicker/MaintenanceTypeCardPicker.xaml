<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="BAAZ.CMMS.App.Controls.MaintenanceTypePicker.MaintenanceTypeCardPicker"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="using:BAAZ.CMMS.App.Controls.MaintenanceTypePicker"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <ItemsControl x:Name="CardsList"
                  HorizontalAlignment="Stretch"
                  ItemsSource="{x:Bind Items, Mode=OneWay}">
        <ItemsControl.ItemContainerStyle>
            <Style TargetType="ContentPresenter">
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            </Style>
        </ItemsControl.ItemContainerStyle>
        <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="local:MaintenanceTypePickerItem">
                <local:MaintenanceTypePickerCard Title="{x:Bind Title}"
                                                 Description="{x:Bind Description}"
                                                 ItemKey="{x:Bind Key}"
                                                 SelectedKey="{Binding ElementName=Root, Path=SelectedKey, Mode=OneWay}"
                                                 RadioGroupName="{Binding ElementName=Root, Path=RadioGroupName, Mode=OneWay}"
                                                 SelectionRequested="OnCardSelectionRequested"
                                                 HorizontalAlignment="Stretch"
                                                 Margin="0,0,0,8" />
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>
