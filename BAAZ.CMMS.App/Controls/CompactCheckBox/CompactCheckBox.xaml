<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="BAAZ.CMMS.App.Controls.CompactCheckBox"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             IsTabStop="True"
             Width="{x:Bind BoxSize, Mode=OneWay}"
             Height="{x:Bind BoxSize, Mode=OneWay}"
             HorizontalAlignment="Center"
             VerticalAlignment="Center">

    <Border x:Name="BoxBorder"
            Width="{x:Bind BoxSize, Mode=OneWay}"
            Height="{x:Bind BoxSize, Mode=OneWay}"
            CornerRadius="{x:Bind BoxCornerRadius, Mode=OneWay}"
            BorderThickness="1"
            Background="Transparent"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
        <Grid>
            <FontIcon x:Name="CheckIcon"
                      Glyph="&#xE73E;"
                      FontSize="9"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Visibility="Collapsed" />
            <Border x:Name="IndeterminateBar"
                    Height="2"
                    Width="8"
                    CornerRadius="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="Collapsed" />
        </Grid>
    </Border>
</UserControl>
