<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="BAAZ.CMMS.App.Controls.LocationTree.LocationTreePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="using:BAAZ.CMMS.Core.Models"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             mc:Ignorable="d">

    <UserControl.Resources>
        <DataTemplate x:Key="DefaultLocationTreeItemTemplate" x:DataType="models:LocationTreeItem">
            <TreeViewItem ItemsSource="{x:Bind Children}"
                          Content="{x:Bind Name}" />
        </DataTemplate>
    </UserControl.Resources>

    <Grid RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              ColumnSpacing="8"
              Visibility="{x:Bind ShowSearchBox, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox x:Name="SearchBox"
                     Grid.Column="0"
                     PlaceholderText="{x:Bind SearchPlaceholder, Mode=OneWay}"
                     TextChanged="SearchBox_TextChanged" />

            <Button x:Name="SearchDialogButton"
                    Grid.Column="1"
                    Click="SearchDialogButton_Click"
                    Style="{ThemeResource DefaultButtonStyle}"
                    IsEnabled="{x:Bind IsSearchDialogButtonEnabled, Mode=OneWay}"
                    Visibility="{x:Bind ShowSearchDialogButton, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="{x:Bind SearchDialogButtonLabel, Mode=OneWay}"
                           VerticalAlignment="Center" />
            </Button>
        </Grid>

        <InfoBar Grid.Row="1"
                 x:Name="NoResultsBar"
                 IsOpen="False"
                 IsClosable="False"
                 Severity="Informational"
                 Message="{x:Bind NoResultsMessage, Mode=OneWay}" />

        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      ZoomMode="Disabled"
                      MinHeight="{x:Bind TreeMinHeight, Mode=OneWay}"
                      MaxHeight="{x:Bind TreeMaxHeight, Mode=OneWay}">
            <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="0,4">
                <TreeView x:Name="Tree"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Top"
                          ItemTemplate="{x:Bind ItemTemplate, Mode=OneWay}" />
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
