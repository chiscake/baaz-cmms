<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="BAAZ.CMMS.App.Pages.Requester.RequesterAssets.RequesterAssetsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:layout="using:WinUI.UtilsLibrary.Controls.PageLayout"
      xmlns:local="using:BAAZ.CMMS.App.Pages.Requester.RequesterAssets"
      mc:Ignorable="d">

    <layout:PageLayout Header="{x:Bind ViewModel.PageTitle, Mode=OneWay}"
                       State="{x:Bind ViewModel.InfoBanner, Mode=OneWay}"
                       MaxContentWidth="Small640">
        <Grid RowDefinitions="Auto,Auto,*,Auto">
            <Button Grid.Row="0"
                    Margin="0,0,0,8"
                    HorizontalAlignment="Stretch"
                    Command="{x:Bind ViewModel.OpenNewRequestCommand}">
                <StackPanel Orientation="Horizontal"
                            Spacing="8"
                            HorizontalAlignment="Center">
                    <SymbolIcon Symbol="Add" />
                    <TextBlock Text="{x:Bind ViewModel.NewRequestLabel, Mode=OneWay}" />
                </StackPanel>
            </Button>

            <TextBox Grid.Row="1"
                     Margin="0,0,0,8"
                     PlaceholderText="{x:Bind ViewModel.SearchPlaceholder, Mode=OneWay}"
                     Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <ListView Grid.Row="2"
                      ItemsSource="{x:Bind ViewModel.FilteredItems, Mode=OneWay}"
                      IsItemClickEnabled="True"
                      SelectionMode="None"
                      ItemClick="AssetList_ItemClick">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment"
                                Value="Stretch" />
                        <Setter Property="VerticalContentAlignment"
                                Value="Stretch" />

                        <Setter Property="Padding"
                                Value="8,4" />

                        <Setter Property="Margin"
                                Value="0,0,0,0" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:RequesterAssetListItem">
                        <Grid Padding="12,10"
                              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                              BorderThickness="1"
                              CornerRadius="4"
                              Margin="0,0,0,0">
                            <StackPanel Spacing="4">
                                <TextBlock Text="{x:Bind DisplayLine}"
                                           TextTrimming="CharacterEllipsis"
                                           Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="{x:Bind LocationPath}"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Visibility="{x:Bind LocationPath, Converter={StaticResource NullToVisibilityConverter}}" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <StackPanel Grid.Row="3"
                        Margin="0,8,0,0"
                        Spacing="8">
                <TextBlock Text="{x:Bind ViewModel.EmptyListText, Mode=OneWay}"
                           Visibility="{x:Bind ViewModel.ShowEmptyList, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                           Style="{ThemeResource BodyTextBlockStyle}"
                           TextWrapping="WrapWholeWords" />
                <TextBlock Text="{x:Bind ViewModel.EmptyFilterText, Mode=OneWay}"
                           Visibility="{x:Bind ViewModel.ShowEmptyFilter, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                           Style="{ThemeResource BodyTextBlockStyle}"
                           TextWrapping="WrapWholeWords" />
            </StackPanel>
        </Grid>
    </layout:PageLayout>
</Page>
