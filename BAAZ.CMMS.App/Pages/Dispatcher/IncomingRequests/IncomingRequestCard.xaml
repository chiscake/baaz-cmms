<?xml version="1.0" encoding="utf-8"?>

<UserControl x:Class="BAAZ.CMMS.App.Pages.Dispatcher.IncomingRequests.IncomingRequestCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:badge="using:BAAZ.CMMS.App.Controls.StatusBadge"
             xmlns:marker="using:BAAZ.CMMS.App.Controls.StatusMarker"
             mc:Ignorable="d">

    <Border Padding="12,10"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="4"
            Margin="0,0,0,12">

        <StackPanel Spacing="8">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <marker:StatusMarker Grid.Column="0"
                                     VerticalAlignment="Top"
                                     Margin="0,6,0,0"
                                     ColorKey="{Binding PriorityMarkerColorKey, Mode=OneWay}"
                                     ToolTipText="{Binding PriorityMarkerTooltip, Mode=OneWay}" />

                <TextBlock Grid.Column="1"
                           Text="{Binding Title, Mode=OneWay}"
                           Style="{ThemeResource BodyStrongTextBlockStyle}"
                           TextWrapping="WrapWholeWords" />

                <badge:StatusBadge Grid.Column="2"
                                   VerticalAlignment="Top"
                                   Label="{Binding TypeLabel, Mode=OneWay}"
                                   BackgroundKey="{Binding TypeBadgeBackgroundKey, Mode=OneWay}"
                                   ForegroundKey="{Binding TypeBadgeForegroundKey, Mode=OneWay}" />
            </Grid>

            <TextBlock Style="{ThemeResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap">
                <Run Text="{Binding RequestNumber, Mode=OneWay}" />
                <Run Text=" • "
                     Foreground="{ThemeResource TextFillColorDisabledBrush}" />
                <Run Text="{Binding RequesterName, Mode=OneWay}" />
            </TextBlock>

            <TextBlock Style="{ThemeResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap">
                <Run Text="{Binding AssigneeText, Mode=OneWay}" />
                <Run Text=" • "
                     Foreground="{ThemeResource TextFillColorDisabledBrush}" />
                <Run Text="{Binding CreatedAtText, Mode=OneWay}" />
            </TextBlock>

            <TextBlock Style="{ThemeResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap"
                       Visibility="{Binding ShowOtherDepartments, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <Run Text="{Binding DepartmentsSectionLabel, Mode=OneWay}" />

                <Run Text=": "

                     Foreground="{ThemeResource TextFillColorDisabledBrush}" />

                <Run Text="{Binding OtherDepartmentsText, Mode=OneWay}" />

            </TextBlock>



            <StackPanel Orientation="Horizontal"

                        Spacing="8">

                <Button x:Name="AcceptButton"

                        Visibility="Collapsed" />

                <Button x:Name="RejectButton"

                        Visibility="Collapsed" />

                <Button x:Name="OpenButton"

                        Visibility="Collapsed" />

            </StackPanel>

        </StackPanel>

    </Border>

</UserControl>
