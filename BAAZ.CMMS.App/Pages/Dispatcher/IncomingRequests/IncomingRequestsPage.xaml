<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="BAAZ.CMMS.App.Pages.Dispatcher.IncomingRequests.IncomingRequestsPage"
      x:Name="Root"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:layout="using:WinUI.UtilsLibrary.Controls.PageLayout"
      xmlns:badge="using:BAAZ.CMMS.App.Controls.StatusBadge"
      xmlns:marker="using:BAAZ.CMMS.App.Controls.StatusMarker"
      xmlns:local="using:BAAZ.CMMS.App.Pages.Dispatcher.IncomingRequests"
      mc:Ignorable="d">

    <layout:PageLayout Header="{x:Bind ViewModel.PageTitle, Mode=OneWay}"
                       State="{x:Bind ViewModel.InfoBanner, Mode=OneWay}"
                       VerticalScrollMode="Disabled">
        <Grid VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        Spacing="12"
                        Margin="0,0,0,12">
                <Button Command="{x:Bind ViewModel.RefreshCommand}">
                    <SymbolIcon Symbol="Refresh" />
                </Button>
            </StackPanel>

            <Grid Grid.Row="1"
                  ColumnSpacing="12"
                  VerticalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        VerticalAlignment="Stretch"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderThickness="1"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        Padding="0, 12"
                        CornerRadius="{ThemeResource OverlayCornerRadius}"
                        Margin="0,0,0,4">
                    <Grid VerticalAlignment="Stretch">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0"
                              ColumnSpacing="8"
                              Margin="12,0,12,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <marker:StatusMarker Grid.Column="0"
                                                 IsLarge="True"
                                                 VerticalAlignment="Center"
                                                 ColorKey="{x:Bind ViewModel.NewColumn.MarkerColorKey, Mode=OneWay}"
                                                 ToolTipText="{x:Bind ViewModel.NewColumn.MarkerTooltip, Mode=OneWay}" />
                            <TextBlock Grid.Column="1"
                                       Text="{x:Bind ViewModel.NewColumn.BaseLabel, Mode=OneWay}"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       VerticalAlignment="Center" />
                            <badge:StatusBadge Grid.Column="2"
                                               IsPill="True"
                                               Label="{x:Bind ViewModel.NewColumn.CountText, Mode=OneWay}"
                                               BackgroundKey="{x:Bind ViewModel.ColumnCountBadgeBackgroundKey, Mode=OneWay}"
                                               ForegroundKey="{x:Bind ViewModel.ColumnCountBadgeForegroundKey, Mode=OneWay}" />
                        </Grid>
                        <Border Grid.Row="1"
                                Height="1"
                                Background="{ThemeResource CardStrokeColorDefaultBrush}"
                                Margin="12,0,12,8" />
                        <ScrollViewer Grid.Row="2"
                                      VerticalScrollBarVisibility="Auto"
                                      VerticalScrollMode="Auto"
                                      HorizontalScrollMode="Disabled">
                            <StackPanel>
                                <TextBlock Text="{x:Bind ViewModel.ColumnEmptyText, Mode=OneWay}"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Margin="12,4,0,8"
                                           Visibility="{x:Bind ViewModel.NewColumn.ShowEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                <ListView ItemsSource="{x:Bind ViewModel.NewColumn.Rows, Mode=OneWay}"
                                          SelectionMode="None"
                                          IsItemClickEnabled="False"
                                          ScrollViewer.VerticalScrollMode="Disabled"
                                          ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                          ScrollViewer.HorizontalScrollMode="Disabled"
                                          Padding="12,0,12,0">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            <Setter Property="Padding" Value="0,0,0,4" />
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="local:IncomingRequestRow">
                                            <local:IncomingRequestCard />
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        VerticalAlignment="Stretch"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderThickness="1"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        Padding="0, 12"
                        CornerRadius="{ThemeResource OverlayCornerRadius}"
                        Margin="0,0,0,4">
                    <Grid VerticalAlignment="Stretch">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0"
                              ColumnSpacing="8"
                              Margin="12,0,12,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <marker:StatusMarker Grid.Column="0"
                                                 IsLarge="True"
                                                 VerticalAlignment="Center"
                                                 ColorKey="{x:Bind ViewModel.AcceptedColumn.MarkerColorKey, Mode=OneWay}"
                                                 ToolTipText="{x:Bind ViewModel.AcceptedColumn.MarkerTooltip, Mode=OneWay}" />
                            <TextBlock Grid.Column="1"
                                       Text="{x:Bind ViewModel.AcceptedColumn.BaseLabel, Mode=OneWay}"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       VerticalAlignment="Center" />
                            <badge:StatusBadge Grid.Column="2"
                                               IsPill="True"
                                               Label="{x:Bind ViewModel.AcceptedColumn.CountText, Mode=OneWay}"
                                               BackgroundKey="{x:Bind ViewModel.ColumnCountBadgeBackgroundKey, Mode=OneWay}"
                                               ForegroundKey="{x:Bind ViewModel.ColumnCountBadgeForegroundKey, Mode=OneWay}" />
                        </Grid>
                        <Border Grid.Row="1"
                                Height="1"
                                Background="{ThemeResource CardStrokeColorDefaultBrush}"
                                Margin="12,0,12,8" />
                        <ScrollViewer Grid.Row="2"
                                      VerticalScrollBarVisibility="Auto"
                                      VerticalScrollMode="Auto"
                                      HorizontalScrollMode="Disabled">
                            <StackPanel>
                                <TextBlock Text="{x:Bind ViewModel.ColumnEmptyText, Mode=OneWay}"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Margin="12,4,0,8"
                                           Visibility="{x:Bind ViewModel.AcceptedColumn.ShowEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                <ListView ItemsSource="{x:Bind ViewModel.AcceptedColumn.Rows, Mode=OneWay}"
                                          SelectionMode="None"
                                          IsItemClickEnabled="False"
                                          ScrollViewer.VerticalScrollMode="Disabled"
                                          ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                          ScrollViewer.HorizontalScrollMode="Disabled"
                                          Padding="12,0,12,0">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            <Setter Property="Padding" Value="0,0,0,4" />
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="local:IncomingRequestRow">
                                            <local:IncomingRequestCard />
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        VerticalAlignment="Stretch"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderThickness="1"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        Padding="0, 12"
                        CornerRadius="{ThemeResource OverlayCornerRadius}"
                        Margin="0,0,0,4">
                    <Grid VerticalAlignment="Stretch">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0"
                              ColumnSpacing="8"
                              Margin="12,0,12,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <marker:StatusMarker Grid.Column="0"
                                                 IsLarge="True"
                                                 VerticalAlignment="Center"
                                                 ColorKey="{x:Bind ViewModel.InProgressColumn.MarkerColorKey, Mode=OneWay}"
                                                 ToolTipText="{x:Bind ViewModel.InProgressColumn.MarkerTooltip, Mode=OneWay}" />
                            <TextBlock Grid.Column="1"
                                       Text="{x:Bind ViewModel.InProgressColumn.BaseLabel, Mode=OneWay}"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       VerticalAlignment="Center" />
                            <badge:StatusBadge Grid.Column="2"
                                               IsPill="True"
                                               Label="{x:Bind ViewModel.InProgressColumn.CountText, Mode=OneWay}"
                                               BackgroundKey="{x:Bind ViewModel.ColumnCountBadgeBackgroundKey, Mode=OneWay}"
                                               ForegroundKey="{x:Bind ViewModel.ColumnCountBadgeForegroundKey, Mode=OneWay}" />
                        </Grid>
                        <Border Grid.Row="1"
                                Height="1"
                                Background="{ThemeResource CardStrokeColorDefaultBrush}"
                                Margin="12,0,12,8" />
                        <ScrollViewer Grid.Row="2"
                                      VerticalScrollBarVisibility="Auto"
                                      VerticalScrollMode="Auto"
                                      HorizontalScrollMode="Disabled">
                            <StackPanel>
                                <TextBlock Text="{x:Bind ViewModel.ColumnEmptyText, Mode=OneWay}"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Margin="12,4,0,8"
                                           Visibility="{x:Bind ViewModel.InProgressColumn.ShowEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                <ListView ItemsSource="{x:Bind ViewModel.InProgressColumn.Rows, Mode=OneWay}"
                                          SelectionMode="None"
                                          IsItemClickEnabled="False"
                                          ScrollViewer.VerticalScrollMode="Disabled"
                                          ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                          ScrollViewer.HorizontalScrollMode="Disabled"
                                          Padding="12,0,12,0">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            <Setter Property="Padding" Value="0,0,0,4" />
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="local:IncomingRequestRow">
                                            <local:IncomingRequestCard />
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Border Grid.Column="3"
                        VerticalAlignment="Stretch"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderThickness="1"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        Padding="0, 12"
                        CornerRadius="{ThemeResource OverlayCornerRadius}"
                        Margin="0,0,0,4">
                    <Grid VerticalAlignment="Stretch">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0"
                              ColumnSpacing="8"
                              Margin="12,0,12,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <marker:StatusMarker Grid.Column="0"
                                                 IsLarge="True"
                                                 VerticalAlignment="Center"
                                                 ColorKey="{x:Bind ViewModel.CompletedColumn.MarkerColorKey, Mode=OneWay}"
                                                 ToolTipText="{x:Bind ViewModel.CompletedColumn.MarkerTooltip, Mode=OneWay}" />
                            <TextBlock Grid.Column="1"
                                       Text="{x:Bind ViewModel.CompletedColumn.BaseLabel, Mode=OneWay}"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       VerticalAlignment="Center" />
                            <badge:StatusBadge Grid.Column="2"
                                               IsPill="True"
                                               Label="{x:Bind ViewModel.CompletedColumn.CountText, Mode=OneWay}"
                                               BackgroundKey="{x:Bind ViewModel.ColumnCountBadgeBackgroundKey, Mode=OneWay}"
                                               ForegroundKey="{x:Bind ViewModel.ColumnCountBadgeForegroundKey, Mode=OneWay}" />
                        </Grid>
                        <Border Grid.Row="1"
                                Height="1"
                                Background="{ThemeResource CardStrokeColorDefaultBrush}"
                                Margin="12,0,12,8" />
                        <ScrollViewer Grid.Row="2"
                                      VerticalScrollBarVisibility="Auto"
                                      VerticalScrollMode="Auto"
                                      HorizontalScrollMode="Disabled">
                            <StackPanel>
                                <TextBlock Text="{x:Bind ViewModel.ColumnEmptyText, Mode=OneWay}"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Margin="12,4,0,8"
                                           Visibility="{x:Bind ViewModel.CompletedColumn.ShowEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                <ListView ItemsSource="{x:Bind ViewModel.CompletedColumn.Rows, Mode=OneWay}"
                                          SelectionMode="None"
                                          IsItemClickEnabled="False"
                                          ScrollViewer.VerticalScrollMode="Disabled"
                                          ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                          ScrollViewer.HorizontalScrollMode="Disabled"
                                          Padding="12,0,12,0">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            <Setter Property="Padding" Value="0,0,0,4" />
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="local:IncomingRequestRow">
                                            <local:IncomingRequestCard />
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </layout:PageLayout>
</Page>
