<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="BAAZ.CMMS.App.Pages.Dispatcher.WorkReports.WorkReportsPage"
      x:Name="Root"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:layout="using:WinUI.UtilsLibrary.Controls.PageLayout"
      xmlns:local="using:BAAZ.CMMS.App.Pages.Dispatcher.WorkReports"
      mc:Ignorable="d">

    <layout:PageLayout Header="{x:Bind ViewModel.PageTitle, Mode=OneWay}"
                       State="{x:Bind ViewModel.InfoBanner, Mode=OneWay}"
                       MaxContentWidth="Small640"
                       VerticalScrollMode="Disabled">
        <Grid VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        Spacing="12"
                        Margin="0,0,0,12">
                <ComboBox ItemsSource="{x:Bind ViewModel.TabLabels, Mode=OneWay}"
                          SelectedIndex="{x:Bind ViewModel.SelectedTabIndex, Mode=TwoWay}"
                          MinWidth="180" />
                <TextBox PlaceholderText="{x:Bind ViewModel.FilterPlaceholder, Mode=OneWay}"
                         Text="{x:Bind ViewModel.FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         MinWidth="240" />
                <Button Command="{x:Bind ViewModel.RefreshCommand}">
                    <SymbolIcon Symbol="Refresh" />
                </Button>
            </StackPanel>

            <Grid Grid.Row="1"
                  VerticalAlignment="Stretch">
                <TextBlock Text="{x:Bind ViewModel.EmptyText, Mode=OneWay}"
                           Visibility="{x:Bind ViewModel.ShowEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                           Style="{ThemeResource BodyTextBlockStyle}" />

                <ListView ItemsSource="{x:Bind ViewModel.Rows, Mode=OneWay}"
                          SelectionMode="None"
                          VerticalAlignment="Stretch">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0,4" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:WorkReportsRow">
                            <Border Padding="12,10"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Margin="0,0,0,8">
                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0"
                                                Spacing="4">
                                        <TextBlock Text="{x:Bind SourceText}"
                                                   Style="{ThemeResource BodyStrongTextBlockStyle}"
                                                   TextWrapping="WrapWholeWords" />
                                        <TextBlock Style="{ThemeResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                            <Run Text="{x:Bind RepairDepartmentName}" />
                                            <Run Text=" • " />
                                            <Run Text="{x:Bind TechnicianName}" />
                                            <Run Text=" • " />
                                            <Run Text="{x:Bind DurationText}" />
                                            <Run Text=" • " />
                                            <Run Text="{x:Bind CreatedAtText}" />
                                        </TextBlock>
                                        <TextBlock Text="{x:Bind WorkPerformed}"
                                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextWrapping="WrapWholeWords"
                                                   MaxLines="2"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1"
                                                VerticalAlignment="Center">
                                        <Button Content="{x:Bind Page.ActionOpen, Mode=OneWay}"
                                                Command="{x:Bind Page.OpenSourceCommand}"
                                                CommandParameter="{x:Bind}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>
    </layout:PageLayout>
</Page>
