<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="BAAZ.CMMS.App.Pages.Dispatcher.MaterialRequisition.MaterialRequisitionLineItemControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Border Padding="12"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="4"
            Margin="0,0,0,10">
        <StackPanel Spacing="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Style="{ThemeResource BodyStrongTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                    <Run Text="{x:Bind Row.Owner.LineItemTitlePrefix, Mode=OneWay}" />
                    <Run Text="{x:Bind Row.LineNumber, Mode=OneWay}" />
                </TextBlock>
                <Button Grid.Column="1"
                        VerticalAlignment="Center"
                        Command="{x:Bind Row.Owner.RemoveLineCommand, Mode=OneWay}"
                        CommandParameter="{x:Bind Row, Mode=OneWay}"
                        ToolTipService.ToolTip="{x:Bind Row.Owner.ActionRemoveLine, Mode=OneWay}"
                        Visibility="{x:Bind Row.ShowRemoveButton, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE74D;"
                                  FontSize="14" />
                        <TextBlock Text="{x:Bind Row.Owner.ActionRemoveLine, Mode=OneWay}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>

            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Header="{x:Bind Row.Owner.LineNameHeader, Mode=OneWay}"
                         PlaceholderText="{x:Bind Row.Owner.LineNamePlaceholder, Mode=OneWay}"
                         Text="{x:Bind Row.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox Grid.Column="1"
                         Header="{x:Bind Row.Owner.LineSkuHeader, Mode=OneWay}"
                         PlaceholderText="{x:Bind Row.Owner.LineSkuPlaceholder, Mode=OneWay}"
                         Text="{x:Bind Row.Sku, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>

            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <NumberBox Grid.Column="0"
                           Header="{x:Bind Row.Owner.LineQuantityHeader, Mode=OneWay}"
                           Value="{x:Bind Row.Quantity, Mode=TwoWay}"
                           Minimum="0"
                           SmallChange="1"
                           LargeChange="10"
                           SpinButtonPlacementMode="Compact" />
                <ComboBox Grid.Column="1"
                          Header="{x:Bind Row.Owner.LineUnitHeader, Mode=OneWay}"
                          PlaceholderText="{x:Bind Row.Owner.LineUnitPlaceholder, Mode=OneWay}"
                          ItemsSource="{x:Bind Row.Owner.UnitOptions, Mode=OneWay}"
                          SelectedItem="{x:Bind Row.Unit, Mode=TwoWay}"
                          HorizontalAlignment="Stretch" />
                <TextBox Grid.Column="2"
                         Header="{x:Bind Row.Owner.LineNoteHeader, Mode=OneWay}"
                         PlaceholderText="{x:Bind Row.Owner.LineNotePlaceholder, Mode=OneWay}"
                         Text="{x:Bind Row.LineNote, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
