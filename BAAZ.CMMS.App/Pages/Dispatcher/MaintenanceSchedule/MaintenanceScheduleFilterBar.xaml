<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="BAAZ.CMMS.App.Pages.Dispatcher.MaintenanceSchedule.MaintenanceScheduleFilterBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Grid ColumnSpacing="12"
          Margin="0,0,0,12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" MinWidth="120" />
            <ColumnDefinition Width="2*" MinWidth="160" />
            <ColumnDefinition Width="3*" MinWidth="200" />
            <ColumnDefinition Width="1*" MinWidth="120" />
            <ColumnDefinition Width="2*" MinWidth="160" />
            <ColumnDefinition Width="200" />
        </Grid.ColumnDefinitions>

        <ComboBox Grid.Column="0"
                  HorizontalAlignment="Stretch"
                  Header="{Binding FilterStatusLabel, Mode=OneWay}"
                  ItemsSource="{Binding StatusFilterOptions, Mode=OneWay}"
                  SelectedIndex="{Binding SelectedStatusFilterIndex, Mode=TwoWay}"
                  DisplayMemberPath="Label" />
        <TextBox Grid.Column="1"
                 HorizontalAlignment="Stretch"
                 Header="{Binding FilterSearchLabel, Mode=OneWay}"
                 PlaceholderText="{Binding FilterPlaceholder, Mode=OneWay}"
                 Text="{Binding FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        <ComboBox Grid.Column="2"
                  HorizontalAlignment="Stretch"
                  Header="{Binding FilterAssetLabel, Mode=OneWay}"
                  ItemsSource="{Binding AssetFilterOptions, Mode=OneWay}"
                  SelectedIndex="{Binding SelectedAssetFilterIndex, Mode=TwoWay}"
                  DisplayMemberPath="Label" />
        <ComboBox Grid.Column="3"
                  HorizontalAlignment="Stretch"
                  Header="{Binding FilterTypeLabel, Mode=OneWay}"
                  ItemsSource="{Binding MaintenanceTypeFilterOptions, Mode=OneWay}"
                  SelectedIndex="{Binding SelectedMaintenanceTypeFilterIndex, Mode=TwoWay}"
                  DisplayMemberPath="Label" />
        <ComboBox Grid.Column="4"
                  HorizontalAlignment="Stretch"
                  Header="{Binding FilterDepartmentLabel, Mode=OneWay}"
                  ItemsSource="{Binding DepartmentFilterOptions, Mode=OneWay}"
                  SelectedIndex="{Binding SelectedDepartmentFilterIndex, Mode=TwoWay}"
                  DisplayMemberPath="Label"
                  Visibility="{Binding IsAdmin, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
        <ComboBox x:Name="SortCombo"
                  Grid.Column="5"
                  HorizontalAlignment="Stretch"
                  Header="{Binding SortLabel, Mode=OneWay}"
                  ItemsSource="{Binding SortLabels, Mode=OneWay}"
                  SelectedIndex="{Binding SelectedSortIndex, Mode=TwoWay}" />
    </Grid>
</UserControl>
