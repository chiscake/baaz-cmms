<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="BAAZ.CMMS.App.Pages.Dispatcher.MaintenanceSchedule.MaintenanceScheduleListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="using:BAAZ.CMMS.App.Pages.Dispatcher.MaintenanceSchedule"
             mc:Ignorable="d">

    <Grid VerticalAlignment="Stretch">
        <TextBlock Text="{Binding EmptyText, Mode=OneWay}"
                   Visibility="{Binding ShowEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                   Style="{ThemeResource BodyTextBlockStyle}" />

        <ListView ItemsSource="{Binding Rows, Mode=OneWay}"
                  SelectionMode="None"
                  VerticalAlignment="Stretch"
                  Visibility="{Binding HasRows, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0,4" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:MaintenanceScheduleRow">
                    <local:MaintenanceScheduleCard ActionLayout="Expanded" />
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>
