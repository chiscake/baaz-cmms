<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="BAAZ.CMMS.App.Pages.Dispatcher.ToolRequisition.ToolRequisitionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:layout="using:WinUI.UtilsLibrary.Controls.PageLayout"
      xmlns:local="using:BAAZ.CMMS.App.Pages.Dispatcher.ToolRequisition"
      mc:Ignorable="d">

    <layout:PageLayout Header="{x:Bind ViewModel.PageTitle, Mode=OneWay}"
                       State="{x:Bind ViewModel.InfoBanner, Mode=OneWay}"
                       MaxContentWidth="Small640">
        <StackPanel Spacing="20">
            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          Width="32"
                          Height="32"
                          HorizontalAlignment="Left"
                          Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

            <StackPanel Spacing="12">
                <TextBlock Text="{x:Bind ViewModel.SectionWorkOrder, Mode=OneWay}"
                           Style="{ThemeResource BodyStrongTextBlockStyle}" />

                <TextBlock Text="{x:Bind ViewModel.ContextSummary, Mode=OneWay}"
                           TextWrapping="WrapWholeWords"
                           Visibility="{x:Bind ViewModel.IsWorkOrderLocked, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                <StackPanel Spacing="8"
                            Visibility="{x:Bind ViewModel.ShowWorkOrderPicker, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ComboBox Header="{x:Bind ViewModel.LabelWorkOrderKind, Mode=OneWay}"
                              PlaceholderText="{x:Bind ViewModel.WorkOrderKindPlaceholder, Mode=OneWay}"
                              ItemsSource="{x:Bind ViewModel.WorkOrderKindLabels, Mode=OneWay}"
                              SelectedIndex="{x:Bind ViewModel.SelectedWorkOrderKindIndex, Mode=TwoWay}" />
                    <ComboBox Header="{x:Bind ViewModel.LabelWorkOrder, Mode=OneWay}"
                              PlaceholderText="{x:Bind ViewModel.WorkOrderPlaceholder, Mode=OneWay}"
                              ItemsSource="{x:Bind ViewModel.WorkOrderOptions, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.SelectedWorkOrder, Mode=TwoWay}"
                              DisplayMemberPath="DisplayText"
                              HorizontalAlignment="Stretch" />
                </StackPanel>

                <ComboBox Header="{x:Bind ViewModel.LabelTechnician, Mode=OneWay}"
                          PlaceholderText="{x:Bind ViewModel.TechnicianPlaceholder, Mode=OneWay}"
                          ItemsSource="{x:Bind ViewModel.TechnicianOptions, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SelectedTechnician, Mode=TwoWay}"
                          DisplayMemberPath="FullName"
                          HorizontalAlignment="Stretch" />

                <StackPanel Spacing="8">
                    <TextBlock Text="{x:Bind ViewModel.SectionMode, Mode=OneWay}"
                               Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    <SelectorBar x:Name="ChannelSelector"
                                 Style="{StaticResource TokenViewSelectorBarStyle}"
                                 SelectionChanged="ChannelSelector_SelectionChanged">
                        <SelectorBarItem Text="{x:Bind ViewModel.ModeTmsLabel, Mode=OneWay}"
                                         IsSelected="True" />
                        <SelectorBarItem Text="{x:Bind ViewModel.ModeDocxLabel, Mode=OneWay}" />
                    </SelectorBar>
                </StackPanel>

                <!-- Docx -->
                <StackPanel Spacing="12"
                            Visibility="{x:Bind ViewModel.IsDocxMode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="{x:Bind ViewModel.SectionWarehouse, Mode=OneWay}"
                               Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    <TextBox Header="{x:Bind ViewModel.LabelWarehouseName, Mode=OneWay}"
                             Text="{x:Bind ViewModel.WarehouseName, Mode=TwoWay}" />

                    <TextBlock Text="{x:Bind ViewModel.SectionLines, Mode=OneWay}"
                               Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    <TextBlock Text="{x:Bind ViewModel.SectionLinesHintDocx, Mode=OneWay}"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="WrapWholeWords" />

                    <ItemsControl ItemsSource="{x:Bind ViewModel.Lines, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="local:ToolRequisitionLineRow">
                                <local:ToolRequisitionLineItemControl Row="{x:Bind}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button HorizontalAlignment="Left"
                            Content="{x:Bind ViewModel.ActionAddLine, Mode=OneWay}"
                            Command="{x:Bind ViewModel.AddLineCommand}" />

                    <TextBlock Text="{x:Bind ViewModel.SectionNotes, Mode=OneWay}"
                               Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    <TextBox PlaceholderText="{x:Bind ViewModel.NotesPlaceholder, Mode=OneWay}"
                             Text="{x:Bind ViewModel.Notes, Mode=TwoWay}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="72" />

                    <Button Style="{ThemeResource AccentButtonStyle}"
                            HorizontalAlignment="Left"
                            Content="{x:Bind ViewModel.ActionSubmitDocx, Mode=OneWay}"
                            Command="{x:Bind ViewModel.SubmitDocxCommand}"
                            IsEnabled="{x:Bind ViewModel.CanSubmit, Mode=OneWay}" />
                </StackPanel>

                <!-- TMS -->
                <StackPanel Spacing="12"
                            Visibility="{x:Bind ViewModel.IsTmsMode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <InfoBar IsOpen="{x:Bind ViewModel.ShowTmsMockWarning, Mode=OneWay}"
                             Severity="Warning"
                             IsClosable="False"
                             Message="{x:Bind ViewModel.TmsMockWarningText, Mode=OneWay}" />
                    <TextBlock Text="{x:Bind ViewModel.TmsLiveModeHint, Mode=OneWay}"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="WrapWholeWords"
                               Visibility="{x:Bind ViewModel.IsTmsLiveIntegration, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <TextBlock Text="{x:Bind ViewModel.SectionWarehouseTms, Mode=OneWay}"
                               Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    <ComboBox Header="{x:Bind ViewModel.LabelTmsWarehouse, Mode=OneWay}"
                              PlaceholderText="{x:Bind ViewModel.TmsWarehousePlaceholder, Mode=OneWay}"
                              ItemsSource="{x:Bind ViewModel.TmsWarehouses, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.SelectedTmsWarehouse, Mode=TwoWay}"
                              DisplayMemberPath="Name"
                              HorizontalAlignment="Stretch" />

                    <TextBlock Text="{x:Bind ViewModel.SectionLines, Mode=OneWay}"
                               Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    <TextBlock Text="{x:Bind ViewModel.SectionLinesHintTms, Mode=OneWay}"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="WrapWholeWords" />

                    <ItemsControl ItemsSource="{x:Bind ViewModel.Lines, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="local:ToolRequisitionLineRow">
                                <local:ToolRequisitionLineItemControl Row="{x:Bind}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button HorizontalAlignment="Left"
                            Content="{x:Bind ViewModel.ActionAddLine, Mode=OneWay}"
                            Command="{x:Bind ViewModel.AddLineCommand}" />

                    <TextBlock Text="{x:Bind ViewModel.SectionNotes, Mode=OneWay}"
                               Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    <TextBox PlaceholderText="{x:Bind ViewModel.NotesPlaceholder, Mode=OneWay}"
                             Text="{x:Bind ViewModel.Notes, Mode=TwoWay}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="72" />

                    <TextBlock Text="{x:Bind ViewModel.SectionTmsLinks, Mode=OneWay}"
                               Style="{ThemeResource BodyStrongTextBlockStyle}"
                               Visibility="{x:Bind ViewModel.HasTmsLinks, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <ItemsControl ItemsSource="{x:Bind ViewModel.TmsLinks, Mode=OneWay}"
                                  Visibility="{x:Bind ViewModel.HasTmsLinks, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="local:TmsLinkDisplayItem">
                                <TextBlock TextWrapping="WrapWholeWords"
                                           Margin="0,0,0,4">
                                    <Run FontWeight="SemiBold" Text="{x:Bind WarehouseName}" />
                                    <Run Text=" · TMS " />
                                    <Run Text="{x:Bind TmsRequisitionIdShort}" />
                                    <Run Text=" — " />
                                    <Run Text="{x:Bind StatusLabel}" />
                                </TextBlock>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="{x:Bind ViewModel.DuplicateTmsHint, Mode=OneWay}"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="WrapWholeWords"
                               Visibility="{x:Bind ViewModel.ShowDuplicateTmsHint, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                    <Button Style="{ThemeResource AccentButtonStyle}"
                            HorizontalAlignment="Left"
                            Content="{x:Bind ViewModel.ActionSubmitTms, Mode=OneWay}"
                            Command="{x:Bind ViewModel.SubmitTmsCommand}"
                            IsEnabled="{x:Bind ViewModel.CanSubmitTms, Mode=OneWay}" />
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </layout:PageLayout>
</Page>
