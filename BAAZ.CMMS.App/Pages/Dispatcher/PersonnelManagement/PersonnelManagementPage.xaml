<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="BAAZ.CMMS.App.Pages.Dispatcher.PersonnelManagement.PersonnelManagementPage"
      x:Name="RootPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:layout="using:WinUI.UtilsLibrary.Controls.PageLayout"
      xmlns:crud="using:BAAZ.CMMS.App.Controls.CrudWorkbench"
      mc:Ignorable="d">

    <layout:PageLayout Header="{x:Bind ViewModel.PageTitle, Mode=OneWay}"
                       State="{x:Bind ViewModel.InfoBanner, Mode=OneWay}"
                       VerticalScrollMode="Disabled">

        <crud:CrudWorkbenchPage x:Name="Workbench"
                                VerticalAlignment="Stretch"
                                DataContext="{x:Bind ViewModel}">
            <crud:CrudWorkbenchPage.EditorContent>
                <StackPanel Spacing="16">
                    <!-- ФИО -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="{x:Bind ViewModel.EditorLabelFullName}"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBox Text="{x:Bind ViewModel.EditorFullName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="Иванов Иван Иванович"
                                 MaxLength="{x:Bind ViewModel.EditorFullNameMaxLength, Mode=OneWay}" />
                    </StackPanel>

                    <!-- Специализация -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="{x:Bind ViewModel.EditorLabelSpecialty}"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBox Text="{x:Bind ViewModel.EditorSpecialty, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="Электросварщик"
                                 MaxLength="{x:Bind ViewModel.EditorSpecialtyMaxLength, Mode=OneWay}" />
                    </StackPanel>

                    <!-- Отдел ремонта -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="{x:Bind ViewModel.EditorLabelDepartment}"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                        <ComboBox ItemsSource="{x:Bind ViewModel.Departments, Mode=OneWay}"
                                  SelectedItem="{x:Bind ViewModel.EditorDepartment, Mode=TwoWay}"
                                  DisplayMemberPath="Name"
                                  PlaceholderText="{x:Bind ViewModel.EditorDepartmentPlaceholder, Mode=OneWay}"
                                  HorizontalAlignment="Stretch"
                                  Visibility="{x:Bind ViewModel.IsAdminRole, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <TextBlock Text="{x:Bind ViewModel.DispatcherDepartmentName}"
                                   Visibility="{x:Bind ViewModel.IsDispatcherRole, Converter={StaticResource BoolToVisibilityConverter}}"
                                   Style="{ThemeResource BodyTextBlockStyle}" />
                    </StackPanel>

                    <!-- Активен (только режим редактирования) -->
                    <ToggleSwitch Header="{x:Bind ViewModel.EditorLabelIsActive}"
                                  IsOn="{x:Bind ViewModel.EditorIsActive, Mode=TwoWay}"
                                  Visibility="{x:Bind ViewModel.IsEditingExistingRecord, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                </StackPanel>
            </crud:CrudWorkbenchPage.EditorContent>
        </crud:CrudWorkbenchPage>
    </layout:PageLayout>
</Page>
