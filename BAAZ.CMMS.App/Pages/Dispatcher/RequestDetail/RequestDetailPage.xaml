<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="BAAZ.CMMS.App.Pages.Dispatcher.RequestDetail.RequestDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:layout="using:WinUI.UtilsLibrary.Controls.PageLayout"
      xmlns:badge="using:BAAZ.CMMS.App.Controls.StatusBadge"
      xmlns:local="using:BAAZ.CMMS.App.Pages.Dispatcher.RequestDetail"
      xmlns:models="using:BAAZ.CMMS.App.Models"
      xmlns:myrequests="using:BAAZ.CMMS.App.Pages.Requester.MyRequests"
      xmlns:toolreq="using:BAAZ.CMMS.App.Pages.Dispatcher.ToolRequisition"
      mc:Ignorable="d">

    <layout:PageLayout Header="{x:Bind ViewModel.PageTitle, Mode=OneWay}"
                       State="{x:Bind ViewModel.InfoBanner, Mode=OneWay}"
                       MaxContentWidth="Small640">
        <StackPanel Spacing="16"
                    Visibility="{x:Bind ViewModel.HasDetail, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">

            <!-- Шапка -->
            <StackPanel Spacing="4">
                <TextBlock Text="{x:Bind ViewModel.DetailTitle, Mode=OneWay}"
                           Style="{ThemeResource SubtitleTextBlockStyle}"
                           TextWrapping="WrapWholeWords" />
                <TextBlock Style="{ThemeResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                        <Run Text="{x:Bind ViewModel.LabelNumber, Mode=OneWay}" />
                        <Run Text=": " />
                        <Run Text="{x:Bind ViewModel.DetailNumber, Mode=OneWay}" />
                </TextBlock>
                <badge:StatusBadge HorizontalAlignment="Left"
                                   Label="{x:Bind ViewModel.DetailStatusLabel, Mode=OneWay}"
                                   BackgroundKey="{x:Bind ViewModel.DetailStatusBackgroundKey, Mode=OneWay}"
                                   ForegroundKey="{x:Bind ViewModel.DetailStatusForegroundKey, Mode=OneWay}" />
                <badge:StatusBadge HorizontalAlignment="Left"
                                   Label="{x:Bind ViewModel.InventoryBadgeLabel, Mode=OneWay}"
                                   BackgroundKey="AccentFillColorDefaultBrush"
                                   ForegroundKey="TextOnAccentFillColorPrimaryBrush"
                                   Visibility="{x:Bind ViewModel.IsInventoryRequest, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                <StackPanel Orientation="Horizontal"
                            Spacing="8"
                            Margin="0,8,0,0">
                    <Button Content="{x:Bind ViewModel.ActionExportRepairRequest, Mode=OneWay}"
                            Command="{x:Bind ViewModel.ExportRepairRequestCommand}" />
                    <Button Content="{x:Bind ViewModel.ActionExportRequestCard, Mode=OneWay}"
                            Command="{x:Bind ViewModel.ExportRequestCardCommand}" />
                </StackPanel>
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock>
                        <Run FontWeight="SemiBold"
                             Text="{x:Bind ViewModel.LabelType, Mode=OneWay}" />
                        <Run Text=": " />
                        <Run Text="{x:Bind ViewModel.DetailType, Mode=OneWay}" />
                </TextBlock>
                <TextBlock>
                            <Run FontWeight="SemiBold"
                                 Text="{x:Bind ViewModel.LabelPriority, Mode=OneWay}" />
                            <Run Text=": " />
                            <Run Text="{x:Bind ViewModel.DetailPriority, Mode=OneWay}" />
                </TextBlock>
                <TextBlock>
                            <Run FontWeight="SemiBold"
                                 Text="{x:Bind ViewModel.LabelRepairZone, Mode=OneWay}" />
                            <Run Text=": " />
                            <Run Text="{x:Bind ViewModel.DetailRepairZone, Mode=OneWay}" />
                </TextBlock>
                <TextBlock Visibility="{x:Bind ViewModel.HasContractorName, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Run FontWeight="SemiBold"
                                 Text="{x:Bind ViewModel.ContractorNamePlaceholder, Mode=OneWay}" />
                            <Run Text=": " />
                            <Run Text="{x:Bind ViewModel.DetailContractorName, Mode=OneWay}" />
                </TextBlock>
                <TextBlock>
                        <Run FontWeight="SemiBold"
                             Text="{x:Bind ViewModel.LabelAsset, Mode=OneWay}" />
                        <Run Text=": " />
                        <Run Text="{x:Bind ViewModel.DetailAsset, Mode=OneWay}" />
                </TextBlock>
                <TextBlock TextWrapping="WrapWholeWords">
                        <Run FontWeight="SemiBold"
                             Text="{x:Bind ViewModel.LabelLocation, Mode=OneWay}" />
                        <Run Text=": " />
                        <Run Text="{x:Bind ViewModel.DetailLocation, Mode=OneWay}" />
                </TextBlock>
                <TextBlock Visibility="{x:Bind ViewModel.IsInventoryRequest, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Run FontWeight="SemiBold"
                             Text="{x:Bind ViewModel.LabelInventoryWarehouse, Mode=OneWay}" />
                        <Run Text=": " />
                        <Run Text="{x:Bind ViewModel.InventoryWarehouseDisplay, Mode=OneWay}" />
                </TextBlock>
                <TextBlock Visibility="{x:Bind ViewModel.ShowInventoryHandoffInfo, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Run FontWeight="SemiBold"
                             Text="{x:Bind ViewModel.LabelInventoryHandoff, Mode=OneWay}" />
                        <Run Text=": " />
                        <Run Text="{x:Bind ViewModel.InventoryHandoffDisplay, Mode=OneWay}" />
                </TextBlock>
                <TextBlock Visibility="{x:Bind ViewModel.ShowInventoryReceivedAt, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Run FontWeight="SemiBold"
                             Text="{x:Bind ViewModel.LabelInventoryReceivedAt, Mode=OneWay}" />
                        <Run Text=": " />
                        <Run Text="{x:Bind ViewModel.InventoryReceivedDisplay, Mode=OneWay}" />
                </TextBlock>
                <TextBlock TextWrapping="WrapWholeWords">
                        <Run FontWeight="SemiBold"
                             Text="{x:Bind ViewModel.LabelDescription, Mode=OneWay}" />
                        <Run Text=": " />
                        <Run Text="{x:Bind ViewModel.DetailDescription, Mode=OneWay}" />
                </TextBlock>
                <TextBlock>
                        <Run FontWeight="SemiBold"
                             Text="{x:Bind ViewModel.LabelRequester, Mode=OneWay}" />
                        <Run Text=": " />
                        <Run Text="{x:Bind ViewModel.DetailRequester, Mode=OneWay}" />
                </TextBlock>
                <TextBlock>
                        <Run FontWeight="SemiBold"
                             Text="{x:Bind ViewModel.LabelCreatedAt, Mode=OneWay}" />
                        <Run Text=": " />
                        <Run Text="{x:Bind ViewModel.DetailCreatedAt, Mode=OneWay}" />
                </TextBlock>
                <TextBlock>
                        <Run FontWeight="SemiBold"
                             Text="{x:Bind ViewModel.LabelUpdatedAt, Mode=OneWay}" />
                        <Run Text=": " />
                        <Run Text="{x:Bind ViewModel.DetailUpdatedAt, Mode=OneWay}" />
                </TextBlock>
            </StackPanel>

            <!-- Отделы -->
            <TextBlock Text="{x:Bind ViewModel.SectionDepartments, Mode=OneWay}"
                       Style="{ThemeResource BodyStrongTextBlockStyle}" />
            <ItemsControl ItemsSource="{x:Bind ViewModel.Departments, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="local:RequestDepartmentRow">
                        <Border Padding="8,6"
                                Margin="0,0,0,6"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="4">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                                <FontIcon Glyph="{x:Bind StatusIconGlyph}"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                          VerticalAlignment="Center" />
                                <TextBlock Text="{x:Bind DepartmentName}"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="—"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{x:Bind AssigneeText}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Панель действий -->
            <TextBlock Text="{x:Bind ViewModel.SectionActions, Mode=OneWay}"
                       Style="{ThemeResource BodyStrongTextBlockStyle}" />

            <StackPanel Spacing="8"
                        Visibility="{x:Bind ViewModel.CanAccept, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid ColumnSpacing="8"
                      Visibility="{x:Bind ViewModel.UseDepartmentTechnicianPicker, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"
                                          MinWidth="180" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{x:Bind ViewModel.ActionAssignTechnician, Mode=OneWay}"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               Style="{ThemeResource BodyTextBlockStyle}" />
                    <ComboBox Grid.Column="1"
                              HorizontalAlignment="Stretch"
                              PlaceholderText="{x:Bind ViewModel.TechnicianPickerPlaceholder, Mode=OneWay}"
                              ItemsSource="{x:Bind ViewModel.DepartmentTechnicianOptions, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.SelectedDepartmentTechnician, Mode=TwoWay}" />
                </Grid>
                <Grid ColumnSpacing="8"
                      Visibility="{x:Bind ViewModel.UseOwnDepartmentTechnicianPicker, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"
                                          MinWidth="180" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{x:Bind ViewModel.ActionAssignTechnician, Mode=OneWay}"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               Style="{ThemeResource BodyTextBlockStyle}" />
                    <ComboBox Grid.Column="1"
                              HorizontalAlignment="Stretch"
                              PlaceholderText="{x:Bind ViewModel.TechnicianPickerPlaceholder, Mode=OneWay}"
                              ItemsSource="{x:Bind ViewModel.TechnicianOptions, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.SelectedTechnician, Mode=TwoWay}" />
                </Grid>
                <StackPanel Orientation="Horizontal"
                            Spacing="8">
                    <Button Content="{x:Bind ViewModel.ActionAccept, Mode=OneWay}"
                            Command="{x:Bind ViewModel.AcceptCommand}" />
                    <Button Content="{x:Bind ViewModel.ActionReject, Mode=OneWay}"
                            Command="{x:Bind ViewModel.RejectCommand}" />
                </StackPanel>
            </StackPanel>

            <StackPanel Spacing="8"
                        Visibility="{x:Bind ViewModel.CanAssignTechnician, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid ColumnSpacing="8"
                      Visibility="{x:Bind ViewModel.UseDepartmentTechnicianPicker, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"
                                          MinWidth="180" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{x:Bind ViewModel.ActionAssignTechnician, Mode=OneWay}"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               Style="{ThemeResource BodyTextBlockStyle}" />
                    <ComboBox Grid.Column="1"
                              HorizontalAlignment="Stretch"
                              PlaceholderText="{x:Bind ViewModel.TechnicianPickerPlaceholder, Mode=OneWay}"
                              ItemsSource="{x:Bind ViewModel.DepartmentTechnicianOptions, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.SelectedDepartmentTechnician, Mode=TwoWay}" />
                    <Button Grid.Column="2"
                            VerticalAlignment="Center"
                            Content="{x:Bind ViewModel.ActionAssignTechnician, Mode=OneWay}"
                            Command="{x:Bind ViewModel.AssignTechnicianCommand}" />
                </Grid>
                <Grid ColumnSpacing="8"
                      Visibility="{x:Bind ViewModel.UseOwnDepartmentTechnicianPicker, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"
                                          MinWidth="180" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{x:Bind ViewModel.ActionAssignTechnician, Mode=OneWay}"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               Style="{ThemeResource BodyTextBlockStyle}" />
                    <ComboBox Grid.Column="1"
                              HorizontalAlignment="Stretch"
                              PlaceholderText="{x:Bind ViewModel.TechnicianPickerPlaceholder, Mode=OneWay}"
                              ItemsSource="{x:Bind ViewModel.TechnicianOptions, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.SelectedTechnician, Mode=TwoWay}" />
                    <Button Grid.Column="2"
                            VerticalAlignment="Center"
                            Content="{x:Bind ViewModel.ActionAssignTechnician, Mode=OneWay}"
                            Command="{x:Bind ViewModel.AssignTechnicianCommand}" />
                </Grid>
            </StackPanel>

            <TextBlock Text="{x:Bind ViewModel.DepartmentReportedBannerText, Mode=OneWay}"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       TextWrapping="Wrap"
                       Visibility="{x:Bind ViewModel.ShowDepartmentReportedBanner, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

            <TextBlock Text="{x:Bind ViewModel.ActionsEmptyText, Mode=OneWay}"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       Visibility="{x:Bind ViewModel.ShowNoActions, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

            <StackPanel Orientation="Horizontal"
                        Spacing="8"
                        Visibility="{x:Bind ViewModel.ShowRequisitionActions, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <Button Content="{x:Bind ViewModel.ActionMaterialRequisition, Mode=OneWay}"
                        Command="{x:Bind ViewModel.OpenMaterialRequisitionCommand}"
                        HorizontalAlignment="Left"
                        Visibility="{x:Bind ViewModel.CanCreateMaterialRequisition, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                <Button Content="{x:Bind ViewModel.ActionToolRequisition, Mode=OneWay}"
                        Command="{x:Bind ViewModel.OpenToolRequisitionCommand}"
                        HorizontalAlignment="Left"
                        Visibility="{x:Bind ViewModel.CanCreateToolRequisition, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
            </StackPanel>

            <Button Content="{x:Bind ViewModel.ActionStartWork, Mode=OneWay}"
                    Command="{x:Bind ViewModel.StartWorkCommand}"
                    Style="{ThemeResource AccentButtonStyle}"
                    HorizontalAlignment="Left"
                    Visibility="{x:Bind ViewModel.CanStartWork, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

            <Button Content="{x:Bind ViewModel.ActionConfirmInventoryReceived, Mode=OneWay}"
                    Command="{x:Bind ViewModel.ConfirmInventoryReceivedCommand}"
                    Style="{ThemeResource AccentButtonStyle}"
                    HorizontalAlignment="Left"
                    Visibility="{x:Bind ViewModel.CanConfirmInventoryReceived, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

            <InfoBar IsOpen="{x:Bind ViewModel.ShowAwaitingClerkHandoff, Mode=OneWay}"
                     Severity="Informational"
                     Message="{x:Bind ViewModel.AwaitingClerkHandoffHint, Mode=OneWay}"
                     IsClosable="False" />

            <Grid ColumnSpacing="8"
                  Visibility="{x:Bind ViewModel.CanChangeZone, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"
                                      MinWidth="180" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0"
                            Spacing="8">
                    <ComboBox Header="{x:Bind ViewModel.ActionChangeZone, Mode=OneWay}"
                              HorizontalAlignment="Stretch"
                              PlaceholderText="{x:Bind ViewModel.RepairZonePickerPlaceholder, Mode=OneWay}"
                              ItemsSource="{x:Bind ViewModel.RepairZoneLabels, Mode=OneWay}"
                              SelectedIndex="{x:Bind ViewModel.SelectedRepairZoneIndex, Mode=TwoWay}" />
                    <TextBox PlaceholderText="{x:Bind ViewModel.ContractorNamePlaceholder, Mode=OneWay}"
                             Text="{x:Bind ViewModel.ContractorNameText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Visibility="{x:Bind ViewModel.ShowContractorNameEditor, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                </StackPanel>
                <Button Grid.Column="1"
                        VerticalAlignment="Bottom"
                        Content="{x:Bind ViewModel.ActionApply, Mode=OneWay}"
                        Command="{x:Bind ViewModel.ChangeZoneCommand}" />
            </Grid>

            <Grid ColumnSpacing="8"
                  Visibility="{x:Bind ViewModel.CanTransferDepartment, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"
                                      MinWidth="180" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0"
                          Header="{x:Bind ViewModel.ActionTransferDepartment, Mode=OneWay}"
                          HorizontalAlignment="Stretch"
                          PlaceholderText="{x:Bind ViewModel.DepartmentPickerPlaceholder, Mode=OneWay}"
                          ItemsSource="{x:Bind ViewModel.TransferDepartmentOptions, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SelectedTransferDepartment, Mode=TwoWay}" />
                <Button Grid.Column="1"
                        VerticalAlignment="Bottom"
                        Content="{x:Bind ViewModel.ActionApply, Mode=OneWay}"
                        Command="{x:Bind ViewModel.TransferDepartmentCommand}" />
            </Grid>

            <Grid ColumnSpacing="8"
                  Visibility="{x:Bind ViewModel.CanAddDepartment, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"
                                      MinWidth="180" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0"
                          Header="{x:Bind ViewModel.ActionAddDepartment, Mode=OneWay}"
                          HorizontalAlignment="Stretch"
                          PlaceholderText="{x:Bind ViewModel.DepartmentPickerPlaceholder, Mode=OneWay}"
                          ItemsSource="{x:Bind ViewModel.AddDepartmentOptions, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SelectedAddDepartment, Mode=TwoWay}" />
                <Button Grid.Column="1"
                        VerticalAlignment="Bottom"
                        Content="{x:Bind ViewModel.ActionApply, Mode=OneWay}"
                        Command="{x:Bind ViewModel.AddDepartmentCommand}" />
            </Grid>

            <Button Content="{x:Bind ViewModel.ActionCloseRequest, Mode=OneWay}"
                    Command="{x:Bind ViewModel.CloseRequestCommand}"
                    HorizontalAlignment="Left"
                    Visibility="{x:Bind ViewModel.CanCloseRequest, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

            <!-- Отчёт о работах -->
            <StackPanel Spacing="8"
                        Visibility="{x:Bind ViewModel.CanSubmitWorkReport, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="{x:Bind ViewModel.ActionSubmitWorkReport, Mode=OneWay}"
                           Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <ComboBox Header="{x:Bind ViewModel.WorkReportDepartmentLabel, Mode=OneWay}"
                          HorizontalAlignment="Stretch"
                          PlaceholderText="{x:Bind ViewModel.DepartmentPickerPlaceholder, Mode=OneWay}"
                          ItemsSource="{x:Bind ViewModel.WorkReportDepartmentOptions, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SelectedWorkReportDepartment, Mode=TwoWay}"
                          Visibility="{x:Bind ViewModel.ShowWorkReportDepartmentPicker, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                <TextBlock Style="{ThemeResource BodyTextBlockStyle}">
                        <Run FontWeight="SemiBold"
                             Text="{x:Bind ViewModel.AssignedTechnicianLabel, Mode=OneWay}" />
                        <Run Text=": " />
                        <Run Text="{x:Bind ViewModel.AssignedTechnicianDisplay, Mode=OneWay}" />
                </TextBlock>
                <StackPanel Spacing="4"
                            Visibility="{x:Bind ViewModel.ShowMaintenanceTypePicker, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="{x:Bind ViewModel.MaintenanceTypeLabel, Mode=OneWay}"
                               Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    <TextBlock Text="{x:Bind ViewModel.MaintenanceTypeHint, Mode=OneWay}"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="WrapWholeWords" />
                    <StackPanel Orientation="Horizontal"
                                Spacing="16">
                        <CheckBox Content="{x:Bind ViewModel.MaintenanceTypeTo1Label, Mode=OneWay}"
                                  IsChecked="{x:Bind ViewModel.MaintenanceTypeTo1Selected, Mode=TwoWay}" />
                        <CheckBox Content="{x:Bind ViewModel.MaintenanceTypeTo2Label, Mode=OneWay}"
                                  IsChecked="{x:Bind ViewModel.MaintenanceTypeTo2Selected, Mode=TwoWay}" />
                        <CheckBox Content="{x:Bind ViewModel.MaintenanceTypeKrLabel, Mode=OneWay}"
                                  IsChecked="{x:Bind ViewModel.MaintenanceTypeKrSelected, Mode=TwoWay}" />
                    </StackPanel>
                </StackPanel>
                <TextBox Header="{x:Bind ViewModel.WorkPerformedLabel, Mode=OneWay}"
                         PlaceholderText="{x:Bind ViewModel.WorkPerformedPlaceholder, Mode=OneWay}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Height="70"
                         Text="{x:Bind ViewModel.WorkPerformedText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <NumberBox MinWidth="120"
                           MaxWidth="160"
                           HorizontalAlignment="Left"
                           Header="{x:Bind ViewModel.DurationLabel, Mode=OneWay}"
                           Value="{x:Bind ViewModel.DurationHours, Mode=TwoWay}"
                           Minimum="0"
                           SmallChange="1"
                           LargeChange="5"
                           SpinButtonPlacementMode="Compact" />
                <TextBox Header="{x:Bind ViewModel.PartsUsedLabel, Mode=OneWay}"
                         PlaceholderText="{x:Bind ViewModel.PartsUsedPlaceholder, Mode=OneWay}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Height="70"
                         Text="{x:Bind ViewModel.PartsUsedText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox Header="{x:Bind ViewModel.DefectsFoundLabel, Mode=OneWay}"
                         PlaceholderText="{x:Bind ViewModel.DefectsFoundPlaceholder, Mode=OneWay}"
                         Text="{x:Bind ViewModel.DefectsFoundText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox Header="{x:Bind ViewModel.NotesLabel, Mode=OneWay}"
                         PlaceholderText="{x:Bind ViewModel.NotesPlaceholder, Mode=OneWay}"
                         Text="{x:Bind ViewModel.NotesText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Button Content="{x:Bind ViewModel.ActionSubmitWorkReport, Mode=OneWay}"
                        Command="{x:Bind ViewModel.SubmitWorkReportCommand}"
                        Style="{ThemeResource AccentButtonStyle}"
                        HorizontalAlignment="Left" />
            </StackPanel>

            <!-- Заявки на инструмент (TMS) -->
            <TextBlock Text="{x:Bind ViewModel.SectionToolRequisitions, Mode=OneWay}"
                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                       Visibility="{x:Bind ViewModel.HasToolRequisitionLinks, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
            <ItemsControl ItemsSource="{x:Bind ViewModel.ToolRequisitionLinks, Mode=OneWay}"
                          Visibility="{x:Bind ViewModel.HasToolRequisitionLinks, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="toolreq:TmsLinkDisplayItem">
                        <Border Padding="8,6"
                                Margin="0,0,0,6"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="4">
                            <StackPanel Spacing="2">
                                <TextBlock Style="{ThemeResource CaptionTextBlockStyle}">
                                    <Run Text="{x:Bind WarehouseName}" />
                                    <Run Text=" — " />
                                    <Run Text="{x:Bind StatusLabel}" />
                                </TextBlock>
                                <TextBlock Text="{x:Bind StorekeeperCancelBanner}"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                           Visibility="{x:Bind IsCancelledByStorekeeper, Mode=OneTime, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Отчёты -->
            <TextBlock Text="{x:Bind ViewModel.SectionWorkReports, Mode=OneWay}"
                       Style="{ThemeResource BodyStrongTextBlockStyle}" />
            <TextBlock Text="{x:Bind ViewModel.WorkReportsEmptyText, Mode=OneWay}"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       Visibility="{x:Bind ViewModel.ShowWorkReportsEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
            <ItemsControl ItemsSource="{x:Bind ViewModel.WorkReports, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:WorkReportDisplayItem">
                        <Border Padding="8,6"
                                Margin="0,0,0,6"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="4">
                            <StackPanel Spacing="2">
                                <TextBlock Style="{ThemeResource CaptionTextBlockStyle}">
                                        <Run Text="{x:Bind RepairDepartmentName}" />
                                        <Run Text=" — " />
                                        <Run Text="{x:Bind TechnicianName}" />
                                        <Run Text=" — " />
                                        <Run Text="{x:Bind CreatedAtText}" />
                                </TextBlock>
                                <TextBlock Text="{x:Bind WorkPerformed}"
                                           TextWrapping="WrapWholeWords" />
                                <TextBlock Style="{ThemeResource CaptionTextBlockStyle}"
                                           Text="{x:Bind DurationText}" />
                                <TextBlock Text="{x:Bind MaintenanceTypesText}"
                                           Style="{ThemeResource CaptionTextBlockStyle}" />
                                <TextBlock Text="{x:Bind DefectsFound}"
                                           TextWrapping="WrapWholeWords"
                                           Style="{ThemeResource CaptionTextBlockStyle}" />
                                <Button Content="{x:Bind Owner.ActionExportWorkReport, Mode=OneWay}"
                                        Command="{x:Bind Owner.ExportWorkReportCommand}"
                                        CommandParameter="{x:Bind Id}"
                                        HorizontalAlignment="Left"
                                        Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- История -->
            <TextBlock Text="{x:Bind ViewModel.SectionHistory, Mode=OneWay}"
                       Style="{ThemeResource BodyStrongTextBlockStyle}" />
            <TextBlock Text="{x:Bind ViewModel.HistoryEmptyText, Mode=OneWay}"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       Visibility="{x:Bind ViewModel.ShowHistoryEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
            <ItemsControl ItemsSource="{x:Bind ViewModel.HistoryItems, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="myrequests:RequestHistoryDisplayItem">
                        <StackPanel Margin="0,0,0,8"
                                    Spacing="2">
                            <TextBlock Style="{ThemeResource CaptionTextBlockStyle}">
                                    <Run Text="{x:Bind CreatedAtText}" />
                                    <Run Text=" — " />
                                    <Run Text="{x:Bind ChangedByName}" />
                            </TextBlock>
                            <TextBlock Text="{x:Bind StatusLineText}"
                                       Style="{ThemeResource BodyTextBlockStyle}" />
                            <TextBlock Text="{x:Bind Comment}"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </layout:PageLayout>
</Page>
