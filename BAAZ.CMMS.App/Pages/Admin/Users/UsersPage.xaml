<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="BAAZ.CMMS.App.Pages.Admin.Users.UsersPage"
      x:Name="RootPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:layout="using:WinUI.UtilsLibrary.Controls.PageLayout"
      xmlns:crud="using:BAAZ.CMMS.App.Controls.CrudWorkbench"
      xmlns:picker="using:BAAZ.CMMS.App.Controls.LocationPicker"
      xmlns:scopepicker="using:BAAZ.CMMS.App.Controls.LocationScopePicker"
      mc:Ignorable="d">

    <layout:PageLayout Header="{x:Bind ViewModel.PageTitle, Mode=OneWay}"
                       State="{x:Bind ViewModel.InfoBanner, Mode=OneWay}"
                       VerticalScrollMode="Disabled">

        <crud:CrudWorkbenchPage x:Name="Workbench"
                                  VerticalAlignment="Stretch"
                                  DataContext="{x:Bind ViewModel}">
            <crud:CrudWorkbenchPage.EditorContent>
                <StackPanel Spacing="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{x:Bind ViewModel.EditorLabelEmail, Mode=OneWay}"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBox Text="{x:Bind ViewModel.EditorEmail, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 MaxLength="{x:Bind ViewModel.EditorEmailMaxLength, Mode=OneWay}" />
                    </StackPanel>

                    <StackPanel Spacing="4"
                                Visibility="{x:Bind ViewModel.IsNewRecord, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{x:Bind ViewModel.EditorLabelPassword, Mode=OneWay}"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{x:Bind ViewModel.EditorPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Grid.Column="0" />
                            <Button Grid.Column="1"
                                    Content="{x:Bind ViewModel.ToolbarGeneratePassword, Mode=OneWay}"
                                    Click="GeneratePassword_Click"
                                    VerticalAlignment="Stretch" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="{x:Bind ViewModel.EditorLabelFullName, Mode=OneWay}"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBox Text="{x:Bind ViewModel.EditorFullName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 MaxLength="{x:Bind ViewModel.EditorFullNameMaxLength, Mode=OneWay}" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="{x:Bind ViewModel.EditorLabelRole, Mode=OneWay}"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <ComboBox ItemsSource="{x:Bind ViewModel.RoleOptions, Mode=OneWay}"
                                  SelectedItem="{x:Bind ViewModel.EditorRole, Mode=TwoWay}"
                                  DisplayMemberPath="DisplayName"
                                  HorizontalAlignment="Stretch" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="{x:Bind ViewModel.EditorLabelLocation, Mode=OneWay}"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <picker:LocationPicker x:Name="EditorLocationPicker"
                                                     Loaded="EditorLocationPicker_Loaded"
                                                     LocationPaths="{x:Bind ViewModel.LocationFullPaths, Mode=OneWay}"
                                                     DisabledNodeIds="{x:Bind ViewModel.DisabledLocationIds, Mode=OneWay}"
                                                     AllowClearSelection="False"
                                                     ShowDialogButton="True"
                                                     ClearParentLabel="{x:Bind ViewModel.EditorClearLocation, Mode=OneWay}" />
                    </StackPanel>

                    <StackPanel Spacing="4"
                                Visibility="{x:Bind ViewModel.ShowScopeEditor, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{x:Bind ViewModel.EditorLabelLocationScopes, Mode=OneWay}"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <scopepicker:LocationScopePicker x:Name="EditorLocationScopePicker"
                                                         Loaded="EditorLocationScopePicker_Loaded"
                                                         LocationPaths="{x:Bind ViewModel.LocationFullPaths, Mode=OneWay}"
                                                         ShowDialogButton="True" />
                    </StackPanel>

                    <StackPanel Spacing="4"
                                Visibility="{x:Bind ViewModel.ShowDepartmentEditor, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{x:Bind ViewModel.EditorLabelDepartment, Mode=OneWay}"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <ComboBox ItemsSource="{x:Bind ViewModel.Departments, Mode=OneWay}"
                                  SelectedItem="{x:Bind ViewModel.EditorDepartment, Mode=TwoWay}"
                                  DisplayMemberPath="Name"
                                  PlaceholderText="{x:Bind ViewModel.EditorDepartmentPlaceholder, Mode=OneWay}"
                                  HorizontalAlignment="Stretch" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="{x:Bind ViewModel.EditorLabelPhone, Mode=OneWay}"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBox Text="{x:Bind ViewModel.EditorPhone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 MaxLength="50" />
                    </StackPanel>
                </StackPanel>
            </crud:CrudWorkbenchPage.EditorContent>
        </crud:CrudWorkbenchPage>
    </layout:PageLayout>
</Page>
