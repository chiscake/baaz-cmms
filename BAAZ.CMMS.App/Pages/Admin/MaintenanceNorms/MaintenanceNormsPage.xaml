<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="BAAZ.CMMS.App.Pages.Admin.MaintenanceNorms.MaintenanceNormsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:layout="using:WinUI.UtilsLibrary.Controls.PageLayout"
      xmlns:breakpoint="using:WinUI.UtilsLibrary.Controls.BreakpointContent"
      xmlns:local="using:BAAZ.CMMS.App.Pages.Admin.MaintenanceNorms"
      xmlns:helpers="using:BAAZ.CMMS.App.Helpers"
      x:Name="RootPage"
      mc:Ignorable="d">

    <layout:PageLayout Header="{x:Bind ViewModel.PageTitle, Mode=OneWay}"
                       State="{x:Bind ViewModel.InfoBanner, Mode=OneWay}"
                       VerticalScrollMode="Disabled">
        <Grid VerticalAlignment="Stretch"
              RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <SelectorBar x:Name="TabSelector"
                         Grid.Row="0"
                         SelectionChanged="TabSelector_SelectionChanged">
                <SelectorBarItem Text="{x:Bind ViewModel.LabelAssetsTab}"
                                 IsSelected="True" />
                <SelectorBarItem Text="{x:Bind ViewModel.LabelCategoriesTab}" />
                <SelectorBarItem Text="{x:Bind ViewModel.LabelAuditTab}" />
            </SelectorBar>

            <!-- Вкладка «По оборудованию» -->
            <Grid x:Name="AssetsTabPanel"
                  Grid.Row="1"
                  VerticalAlignment="Stretch"
                  ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0"
                      VerticalAlignment="Stretch"
                      RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBox Grid.Row="0"
                             PlaceholderText="{x:Bind ViewModel.AssetSearchPlaceholder}"
                             Text="{x:Bind ViewModel.AssetSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <ListView x:Name="AssetListView"
                              Grid.Row="1"
                              VerticalAlignment="Stretch"
                              ItemsSource="{x:Bind ViewModel.AssetSuggestions, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.SelectedAssetRow, Mode=OneWay}"
                              SelectionMode="Single"
                              SelectionChanged="AssetList_SelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:AssetPickerRow">
                                <TextBlock Text="{x:Bind DisplayName}"
                                           TextTrimming="CharacterEllipsis" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>

                <Grid Grid.Column="1"
                      VerticalAlignment="Stretch">
                    <breakpoint:BreakpointContent MaxContentWidth="Medium768"
                                                  Background="{ThemeResource LayerFillColorDefaultBrush}"
                                                  ContentPadding="16"
                                                  VerticalAlignment="Stretch"
                                                  HorizontalAlignment="Stretch"
                                                  Visibility="{x:Bind ViewModel.ShowAssetEmptySelection, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{x:Bind ViewModel.SelectFromListHint, Mode=OneWay}"
                                   Style="{ThemeResource BodyTextBlockStyle}"
                                   TextWrapping="WrapWholeWords"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Opacity="0.7" />
                    </breakpoint:BreakpointContent>

                    <Grid VerticalAlignment="Stretch"
                          Visibility="{x:Bind ViewModel.IsAssetSelected, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <breakpoint:BreakpointContent MaxContentWidth="Medium768"
                                                  Background="{ThemeResource LayerFillColorDefaultBrush}"
                                                  ContentPadding="16"
                                                  VerticalAlignment="Stretch"
                                                  HorizontalAlignment="Stretch">
                        <ScrollViewer VerticalAlignment="Stretch"
                                      HorizontalAlignment="Stretch"
                                      HorizontalContentAlignment="Stretch"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="16"
                                        HorizontalAlignment="Stretch">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{x:Bind ViewModel.AssetHeaderText, Mode=OneWay}"
                                           Style="{ThemeResource SubtitleTextBlockStyle}" />
                                <TextBlock Text="{x:Bind ViewModel.AssetCategoryText, Mode=OneWay}"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Opacity="0.7" />
                            </StackPanel>

                            <ItemsControl ItemsSource="{x:Bind ViewModel.AssetSlots, Mode=OneWay}"
                                          HorizontalAlignment="Stretch">
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="local:AssetSlotEditor">
                                        <Expander Header="{x:Bind}"
                                                  IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}"
                                                  HorizontalAlignment="Stretch"
                                                  HorizontalContentAlignment="Stretch"
                                                  Margin="0,0,0,8">
                                            <Expander.HeaderTemplate>
                                                <DataTemplate x:DataType="local:AssetSlotEditor">
                                                    <StackPanel Orientation="Horizontal"
                                                                Spacing="8">
                                                        <TextBlock Text="{x:Bind Header}"
                                                                   VerticalAlignment="Center" />
                                                        <InfoBadge Style="{StaticResource CautionIconInfoBadgeStyle}"
                                                                   Visibility="{x:Bind IsPendingScheduleVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                                            <ToolTipService.ToolTip>
                                                                <ToolTip Content="{x:Bind PendingScheduleTooltip}" />
                                                            </ToolTipService.ToolTip>
                                                        </InfoBadge>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </Expander.HeaderTemplate>

                                            <StackPanel Spacing="12"
                                                        Padding="4"
                                                        HorizontalAlignment="Stretch">
                                                <TextBlock Text="{x:Bind PresetSummary}"
                                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                                           TextWrapping="Wrap" />

                                                <ToggleSwitch Header="{x:Bind local:MaintenanceNormsPage.OverrideLabel}"
                                                              IsOn="{x:Bind HasOverride, Mode=TwoWay}" />

                                                <StackPanel Spacing="8"
                                                            Visibility="{x:Bind HasOverride, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <NumberBox Header="{x:Bind local:MaintenanceNormsPage.IntervalLabel}"
                                                               Value="{x:Bind IntervalDays, Mode=TwoWay}"
                                                               SpinButtonPlacementMode="Compact"
                                                               Minimum="1" />

                                                    <TextBox Header="{x:Bind local:MaintenanceNormsPage.DescriptionLabel}"
                                                             Text="{x:Bind Description, Mode=TwoWay}"
                                                             AcceptsReturn="True"
                                                             TextWrapping="Wrap"
                                                             MinHeight="60" />

                                                    <ItemsControl ItemsSource="{x:Bind Departments}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="helpers:CheckableItem">
                                                                <CheckBox Content="{x:Bind Name}"
                                                                          IsChecked="{x:Bind IsChecked, Mode=TwoWay}" />
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>

                                                <TextBlock Text="{x:Bind StatusSummary}"
                                                           Style="{ThemeResource CaptionTextBlockStyle}" />

                                                <Button Content="{x:Bind local:MaintenanceNormsPage.ResetToPresetLabel}"
                                                        Command="{Binding ViewModel.ResetSlotToPresetCommand, ElementName=RootPage}"
                                                        CommandParameter="{x:Bind}"
                                                        HorizontalAlignment="Left" />
                                            </StackPanel>
                                        </Expander>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Button Content="{x:Bind ViewModel.SaveAssetLabel}"
                                    Command="{x:Bind ViewModel.SaveAssetNormsCommand}"
                                    Style="{ThemeResource AccentButtonStyle}"
                                    HorizontalAlignment="Left" />
                            </StackPanel>
                        </ScrollViewer>
                    </breakpoint:BreakpointContent>
                    </Grid>
                </Grid>
            </Grid>

            <!-- Вкладка «Категории» -->
            <Grid x:Name="CategoriesTabPanel"
                  Grid.Row="1"
                  VerticalAlignment="Stretch"
                  ColumnSpacing="16"
                  Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0"
                      VerticalAlignment="Stretch"
                      RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0"
                            Content="{x:Bind ViewModel.AddCategoryLabel}"
                            Command="{x:Bind ViewModel.AddCategoryCommand}"
                            HorizontalAlignment="Stretch" />

                    <ListView x:Name="CategoryListView"
                              Grid.Row="1"
                              VerticalAlignment="Stretch"
                              ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.SelectedCategoryRow, Mode=OneWay}"
                              SelectionMode="Single"
                              SelectionChanged="CategoryList_SelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:CategoryRow">
                                <StackPanel>
                                    <TextBlock Text="{x:Bind Name}" />
                                    <TextBlock Text="{x:Bind Description}"
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               Opacity="0.7"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>

                <Grid Grid.Column="1"
                      VerticalAlignment="Stretch">
                    <breakpoint:BreakpointContent MaxContentWidth="Medium768"
                                                  Background="{ThemeResource LayerFillColorDefaultBrush}"
                                                  ContentPadding="16"
                                                  VerticalAlignment="Stretch"
                                                  HorizontalAlignment="Stretch"
                                                  Visibility="{x:Bind ViewModel.ShowCategoryEmptySelection, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{x:Bind ViewModel.SelectFromListHint, Mode=OneWay}"
                                   Style="{ThemeResource BodyTextBlockStyle}"
                                   TextWrapping="WrapWholeWords"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Opacity="0.7" />
                    </breakpoint:BreakpointContent>

                    <Grid VerticalAlignment="Stretch"
                          Visibility="{x:Bind ViewModel.IsCategoryEditorVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <breakpoint:BreakpointContent MaxContentWidth="Medium768"
                                                  Background="{ThemeResource LayerFillColorDefaultBrush}"
                                                  ContentPadding="16"
                                                  VerticalAlignment="Stretch"
                                                  HorizontalAlignment="Stretch">
                        <ScrollViewer VerticalAlignment="Stretch"
                                      HorizontalAlignment="Stretch"
                                      HorizontalContentAlignment="Stretch"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="16"
                                        HorizontalAlignment="Stretch">
                            <TextBox Header="{x:Bind ViewModel.CategoryNameLabel}"
                                     Text="{x:Bind ViewModel.CategoryEditorName, Mode=TwoWay}" />

                            <TextBox Header="{x:Bind ViewModel.CategoryDescriptionLabel}"
                                     Text="{x:Bind ViewModel.CategoryEditorDescription, Mode=TwoWay}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinHeight="60" />

                            <ItemsControl ItemsSource="{x:Bind ViewModel.CategorySlots, Mode=OneWay}"
                                          HorizontalAlignment="Stretch">
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="local:CategorySlotEditor">
                                        <Expander Header="{x:Bind Header}"
                                                  IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}"
                                                  HorizontalAlignment="Stretch"
                                                  HorizontalContentAlignment="Stretch"
                                                  Margin="0,0,0,8">
                                            <StackPanel Spacing="8"
                                                        Padding="4"
                                                        HorizontalAlignment="Stretch">
                                                <ToggleSwitch Header="{x:Bind local:MaintenanceNormsPage.EnabledLabel}"
                                                              IsOn="{x:Bind IsEnabled, Mode=TwoWay}" />

                                                <StackPanel Spacing="8"
                                                            Visibility="{x:Bind IsEnabled, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <NumberBox Header="{x:Bind local:MaintenanceNormsPage.IntervalLabel}"
                                                               Value="{x:Bind IntervalDays, Mode=TwoWay}"
                                                               SpinButtonPlacementMode="Compact"
                                                               Minimum="1" />

                                                    <TextBox Header="{x:Bind local:MaintenanceNormsPage.DescriptionLabel}"
                                                             Text="{x:Bind Description, Mode=TwoWay}"
                                                             AcceptsReturn="True"
                                                             TextWrapping="Wrap"
                                                             MinHeight="60" />

                                                    <ItemsControl ItemsSource="{x:Bind Departments}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="helpers:CheckableItem">
                                                                <CheckBox Content="{x:Bind Name}"
                                                                          IsChecked="{x:Bind IsChecked, Mode=TwoWay}" />
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </StackPanel>
                                        </Expander>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Button Content="{x:Bind ViewModel.SaveCategoryLabel}"
                                    Command="{x:Bind ViewModel.SaveCategoryCommand}"
                                    Style="{ThemeResource AccentButtonStyle}"
                                    HorizontalAlignment="Left" />
                            </StackPanel>
                        </ScrollViewer>
                    </breakpoint:BreakpointContent>
                    </Grid>
                </Grid>
            </Grid>

            <!-- Вкладка «Все нормативы» -->
            <ListView x:Name="AuditTabPanel"
                      Grid.Row="1"
                      VerticalAlignment="Stretch"
                      ItemsSource="{x:Bind ViewModel.AuditGroups, Mode=OneWay}"
                      Visibility="Collapsed"
                      SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:AuditAssetGroup">
                        <StackPanel Margin="0,8"
                                    Spacing="4">
                            <TextBlock Text="{x:Bind Header}"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}" />
                            <ItemsControl ItemsSource="{x:Bind Items}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="local:AuditNormRow">
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="12"
                                                    Margin="16,0,0,0">
                                            <TextBlock Text="{x:Bind MaintenanceTypeLabel}"
                                                       Width="60" />
                                            <TextBlock Text="{x:Bind IntervalSummary}" />
                                            <TextBlock Text="{x:Bind NextMaintenanceText}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </layout:PageLayout>
</Page>
