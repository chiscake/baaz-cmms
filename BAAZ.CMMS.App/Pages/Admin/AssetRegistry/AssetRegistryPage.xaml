<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="BAAZ.CMMS.App.Pages.Admin.AssetRegistry.AssetRegistryPage"
      x:Name="RootPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:layout="using:WinUI.UtilsLibrary.Controls.PageLayout"
      xmlns:crud="using:BAAZ.CMMS.App.Controls.CrudWorkbench"
      xmlns:picker="using:BAAZ.CMMS.App.Controls.LocationPicker"
      mc:Ignorable="d">

    <layout:PageLayout Header="{x:Bind ViewModel.PageTitle, Mode=OneWay}"
                       State="{x:Bind ViewModel.InfoBanner, Mode=OneWay}"
                       VerticalScrollMode="Disabled">

        <crud:CrudWorkbenchPage x:Name="Workbench"
                                  VerticalAlignment="Stretch"
                                  DataContext="{x:Bind ViewModel}">
            <crud:CrudWorkbenchPage.EditorContent>
                <StackPanel Spacing="16" MinWidth="0">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{x:Bind ViewModel.EditorLabelAssetNumber, Mode=OneWay}"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBox Loaded="EditorField_Loaded"
                                 Text="{x:Bind ViewModel.EditorAssetNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 MaxLength="{x:Bind ViewModel.EditorAssetNumberMaxLength, Mode=OneWay}" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="{x:Bind ViewModel.EditorLabelName, Mode=OneWay}"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBox Text="{x:Bind ViewModel.EditorName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 MaxLength="{x:Bind ViewModel.EditorNameMaxLength, Mode=OneWay}" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="{x:Bind ViewModel.EditorLabelLocation, Mode=OneWay}"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <picker:LocationPicker x:Name="EditorLocationPicker"
                                               Loaded="EditorLocationPicker_Loaded"
                                               LocationPaths="{x:Bind ViewModel.LocationFullPaths, Mode=OneWay}"
                                               AllowClearSelection="False"
                                               ShowDialogButton="True"
                                               ClearParentLabel="{x:Bind ViewModel.EditorClearLocation, Mode=OneWay}" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="{x:Bind ViewModel.EditorLabelCategory, Mode=OneWay}"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <ComboBox x:Name="EditorCategoryComboBox"
                                  Loaded="EditorField_Loaded"
                                  ItemsSource="{x:Bind ViewModel.CategoryOptions, Mode=OneWay}"
                                  SelectedValue="{x:Bind ViewModel.EditorCategoryId, Mode=TwoWay}"
                                  SelectedValuePath="Id"
                                  DisplayMemberPath="Name"
                                  PlaceholderText="{x:Bind ViewModel.EditorCategoryPlaceholder, Mode=OneWay}"
                                  MinWidth="0"
                                  HorizontalAlignment="Stretch" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="{x:Bind ViewModel.EditorLabelManufacturer, Mode=OneWay}"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBox Text="{x:Bind ViewModel.EditorManufacturer, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 MaxLength="{x:Bind ViewModel.EditorManufacturerMaxLength, Mode=OneWay}" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="{x:Bind ViewModel.EditorLabelModel, Mode=OneWay}"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBox Text="{x:Bind ViewModel.EditorModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 MaxLength="{x:Bind ViewModel.EditorModelMaxLength, Mode=OneWay}" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="{x:Bind ViewModel.EditorLabelSerialNumber, Mode=OneWay}"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBox Text="{x:Bind ViewModel.EditorSerialNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 MaxLength="{x:Bind ViewModel.EditorSerialNumberMaxLength, Mode=OneWay}" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="{x:Bind ViewModel.EditorLabelCommissioningDate, Mode=OneWay}"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <CalendarDatePicker x:Name="EditorCommissioningDatePicker"
                                            Loaded="EditorField_Loaded"
                                            Date="{x:Bind ViewModel.EditorCommissioningDate, Mode=TwoWay}"
                                            PlaceholderText="—" />
                    </StackPanel>

                    <StackPanel Spacing="4"
                                Visibility="{x:Bind ViewModel.IsEditingExistingRecord, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{x:Bind ViewModel.EditorLabelStatus, Mode=OneWay}"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <ComboBox x:Name="EditorStatusComboBox"
                                  Loaded="EditorField_Loaded"
                                  ItemsSource="{x:Bind ViewModel.StatusOptions, Mode=OneWay}"
                                  SelectedItem="{x:Bind ViewModel.EditorStatus, Mode=TwoWay}"
                                  DisplayMemberPath="Label" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="{x:Bind ViewModel.EditorLabelDescription, Mode=OneWay}"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBox Text="{x:Bind ViewModel.EditorDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 MaxLength="{x:Bind ViewModel.EditorDescriptionMaxLength, Mode=OneWay}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="80" />
                    </StackPanel>
                </StackPanel>
            </crud:CrudWorkbenchPage.EditorContent>
        </crud:CrudWorkbenchPage>
    </layout:PageLayout>
</Page>
