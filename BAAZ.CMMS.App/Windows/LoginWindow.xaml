<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="BAAZ.CMMS.App.Windows.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="rootGrid"
          Loaded="RootGrid_Loaded">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="titleBar"
                  Title="{Binding TitleText, Mode=OneWay}"
                  IsBackButtonVisible="False"
                  IsPaneToggleButtonVisible="False" />

        <Grid Grid.Row="1"
              Padding="28,16,28,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Margin="0,0,0,16"
                        Spacing="4">
                <TextBlock Style="{ThemeResource TitleTextBlockStyle}"
                           Text="{Binding TitleText, Mode=OneWay}" />
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Style="{ThemeResource BodyTextBlockStyle}"
                           Text="{Binding SubtitleText, Mode=OneWay}"
                           TextWrapping="WrapWholeWords" />
            </StackPanel>

            <Border Grid.Row="1"
                    Style="{StaticResource AuthCardStyle}"
                    VerticalAlignment="Top"
                    Visibility="{Binding IsSignInView, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="6">
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Text="{Binding EmailLabel, Mode=OneWay}" />
                        <TextBox x:Name="emailTextBox"
                                 IsSpellCheckEnabled="False"
                                 IsTextPredictionEnabled="False"
                                 PlaceholderText="{Binding EmailPlaceholder, Mode=OneWay}" />
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Text="{Binding PasswordLabel, Mode=OneWay}" />
                        <PasswordBox x:Name="passwordBox"
                                     KeyDown="PasswordBox_KeyDown" />
                    </StackPanel>

                    <Button Margin="0,4,0,0"
                            HorizontalAlignment="Stretch"
                            Click="SignInButton_Click"
                            Content="{Binding SignInButtonText, Mode=OneWay}"
                            Style="{ThemeResource AccentButtonStyle}" />

                    <TextBlock Margin="0,4,0,0"
                               Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Text="{Binding SignInErrorMessage, Mode=OneWay}"
                               TextWrapping="WrapWholeWords" />

                    <HyperlinkButton HorizontalAlignment="Left"
                                     Command="{Binding ShowServerSettingsCommand}"
                                     Content="{Binding ChangeServerText, Mode=OneWay}" />
                </StackPanel>
            </Border>

            <Border Grid.Row="1"
                    Style="{StaticResource AuthCardStyle}"
                    VerticalAlignment="Top"
                    Visibility="{Binding IsServerSettingsView, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="6">
                        <TextBlock Text="{Binding ServerSettings.SupabaseUrlLabel, Mode=OneWay}" />
                        <TextBox Text="{Binding ServerSettings.SupabaseUrl, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="{Binding ServerSettings.SupabaseKeyLabel, Mode=OneWay}" />
                        <TextBox Text="{Binding ServerSettings.SupabaseAnonKey, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel Orientation="Vertical"
                                Spacing="8">
                        <Button Command="{Binding ServerSettings.TestSupabaseConnectionCommand}"
                                Content="{Binding ServerSettings.SupabaseTestButtonText, Mode=OneWay}" />
                        <Button Command="{Binding ServerSettings.SaveSupabaseSettingsCommand}"
                                Content="{Binding ServerSettings.SupabaseSaveButtonText, Mode=OneWay}" />
                    </StackPanel>

                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Text="{Binding ServerSettings.StatusMessage, Mode=OneWay}"
                               TextWrapping="WrapWholeWords" />

                    <HyperlinkButton HorizontalAlignment="Left"
                                     Command="{Binding ShowSignInCommand}"
                                     Content="{Binding BackToSignInText, Mode=OneWay}" />
                </StackPanel>
            </Border>

            <StackPanel x:Name="devQuickLoginPanel"
                        Grid.Row="2"
                        Margin="0,16,0,0"
                        Spacing="8"
                        Visibility="Collapsed">
                <TextBlock Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           Text="Быстрый вход (отладка)" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="devQuickLoginComboBox"
                              Grid.Column="0"
                              HorizontalAlignment="Stretch"
                              DisplayMemberPath="Label"
                              PlaceholderText="Выберите учётную запись" />
                    <Button Grid.Column="1"
                            Click="DevQuickLogin_Click"
                            Content="Войти" />
                </Grid>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
